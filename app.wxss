page {
  /* === 五邑侨乡品牌色系 === */
  /* 主色：碉楼青砖蓝 */
  --brand-color: #1D5F8A;
  --brand-color-light: #E8F2FA;
  --brand-color-dark: #134566;
  --brand-color-active: #0F3A56;
  --brand-gradient: linear-gradient(135deg, #1D5F8A 0%, #134566 50%, #0C2E45 100%);

  /* 侨乡特色辅助色 */
  --qiao-gold: #C8963E;
  --qiao-gold-light: #FBF5EB;
  --qiao-terracotta: #B85C38;
  --qiao-terracotta-light: #FDF2ED;
  --qiao-jade: #2D8B6F;
  --qiao-jade-light: #ECF7F3;

  /* 功能色 */
  --success-color: #2D8B6F;
  --success-light: #ECF7F3;
  --warning-color: #C8963E;
  --warning-light: #FBF5EB;
  --danger-color: #C94545;
  --danger-light: #FDECEE;

  /* 文字色 */
  --text-primary: #1A1A2E;
  --text-secondary: #4A5568;
  --text-tertiary: #9CA3AF;
  --text-inverse: #FFFFFF;

  /* 背景色 */
  --bg-primary: #F5F6FA;
  --bg-card: #FFFFFF;
  --bg-hover: #EEF0F5;
  --bg-warm: #FEFCF8;

  /* 边框与阴影 */
  --border-color: #E8ECF1;
  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.10);
  --shadow-brand: 0 8rpx 24rpx rgba(29, 95, 138, 0.20);
  --shadow-gold: 0 8rpx 24rpx rgba(200, 150, 62, 0.15);

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;

  /* TDesign 覆盖 */
  --td-brand-color: var(--brand-color);

  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
}

/* ========== 全局按钮 ========== */
.btn-primary {
  background: var(--brand-gradient) !important;
  color: var(--text-inverse) !important;
  border-radius: var(--radius-lg) !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  height: 96rpx !important;
  box-shadow: var(--shadow-brand) !important;
  border: none !important;
  letter-spacing: 2rpx;
}
.btn-primary:active {
  opacity: 0.9 !important;
  transform: scale(0.98);
}

.btn-secondary {
  background: var(--bg-card) !important;
  color: var(--brand-color) !important;
  border: 2rpx solid var(--brand-color) !important;
  border-radius: var(--radius-lg) !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
  height: 88rpx !important;
}

.btn-danger {
  background: linear-gradient(135deg, #C94545 0%, #A33535 100%) !important;
  color: var(--text-inverse) !important;
  border-radius: var(--radius-lg) !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  height: 96rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(201, 69, 69, 0.20) !important;
  border: none !important;
}

/* ========== 卡片 ========== */
.glass-card {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  border-radius: var(--radius-xl);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: var(--shadow-md);
  padding: 40rpx;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 40rpx;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  padding-top: 100rpx;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  padding-right: 10rpx;
}
.custom-nav .nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  margin-right: 16rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255,255,255,0.1);
}
.custom-nav .nav-back:active {
  background: rgba(255, 255, 255, 0.25);
}
.custom-nav .nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* ========== 沉浸式背景 ========== */
.immersive-bg {
  position: fixed;
  left: 0; top: 0;
  width: 100%; height: 100vh;
  z-index: 1;
}
.immersive-overlay {
  position: fixed;
  left: 0; top: 0;
  width: 100%; height: 100vh;
  z-index: 2;
}
.immersive-content {
  position: relative;
  z-index: 3;
  min-height: 100vh;
}

/* ========== 状态标签 ========== */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.status-tag.pending {
  background: var(--warning-light);
  color: var(--warning-color);
}
.status-tag.approved {
  background: var(--success-light);
  color: var(--success-color);
}
.status-tag.rejected {
  background: var(--danger-light);
  color: var(--danger-color);
}
.status-tag.active {
  background: var(--brand-color-light);
  color: var(--brand-color);
}

/* ========== 分割线 ========== */
.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}
.divider .line {
  flex: 1;
  height: 2rpx;
  background: var(--border-color);
}
.divider .text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ========== 侨乡纹饰 ========== */
.qiao-pattern-bg {
  background-image:
    radial-gradient(circle at 20% 80%, rgba(200,150,62,0.03) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(29,95,138,0.03) 0%, transparent 50%);
}

.qiao-header-deco {
  position: relative;
}
.qiao-header-deco::after {
  content: '';
  display: block;
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--qiao-gold), transparent);
  border-radius: 2rpx;
  margin-top: 8rpx;
}

/* ========== 安全区适配 ========== */
.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}
