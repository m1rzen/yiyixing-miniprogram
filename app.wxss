page {
  --brand-color: #2B6CB0;
  --brand-color-light: #EBF4FF;
  --brand-color-dark: #1E4E8C;
  --brand-color-active: #1A4178;
  --brand-gradient: linear-gradient(135deg, #2B6CB0 0%, #1E4E8C 100%);

  --success-color: #00A870;
  --success-light: #E8F8F0;
  --warning-color: #ED7B2F;
  --warning-light: #FFF3E8;
  --danger-color: #E34D59;
  --danger-light: #FDECEE;

  --text-primary: #1A1A2E;
  --text-secondary: #4A5568;
  --text-tertiary: #9CA3AF;
  --text-inverse: #FFFFFF;

  --bg-primary: #F7F8FC;
  --bg-card: #FFFFFF;
  --bg-hover: #F0F2F5;

  --border-color: #E8ECF1;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  --shadow-brand: 0 8rpx 24rpx rgba(43, 108, 176, 0.25);

  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;

  --td-brand-color: var(--brand-color);

  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
}

/* 全局主按钮 */
.btn-primary {
  background: var(--brand-gradient) !important;
  color: var(--text-inverse) !important;
  border-radius: var(--radius-md) !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  height: 96rpx !important;
  box-shadow: var(--shadow-brand) !important;
  border: none !important;
  letter-spacing: 2rpx;
}
.btn-primary:active {
  opacity: 0.9 !important;
  transform: scale(0.98);
}

/* 全局次按钮 */
.btn-secondary {
  background: var(--bg-card) !important;
  color: var(--brand-color) !important;
  border: 2rpx solid var(--brand-color) !important;
  border-radius: var(--radius-md) !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
  height: 88rpx !important;
}

/* 全局危险按钮 */
.btn-danger {
  background: linear-gradient(135deg, #E34D59 0%, #C93545 100%) !important;
  color: var(--text-inverse) !important;
  border-radius: var(--radius-md) !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  height: 96rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(227, 77, 89, 0.25) !important;
  border: none !important;
}

/* 毛玻璃卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  border-radius: var(--radius-xl);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: var(--shadow-md);
  padding: 40rpx;
}

/* 纯白卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 40rpx;
}

/* 标准自定义导航栏 */
.custom-nav {
  display: flex;
  align-items: center;
  padding-top: 100rpx;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  padding-right: 10rpx;
}
.custom-nav .nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  margin-right: 16rpx;
}
.custom-nav .nav-back:active {
  background: rgba(255, 255, 255, 0.3);
}
.custom-nav .nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFF;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

/* 沉浸式背景 */
.immersive-bg {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
}
.immersive-overlay {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100vh;
  z-index: 2;
}
.immersive-content {
  position: relative;
  z-index: 3;
  min-height: 100vh;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.status-tag.pending {
  background: var(--warning-light);
  color: var(--warning-color);
}
.status-tag.approved {
  background: var(--success-light);
  color: var(--success-color);
}
.status-tag.rejected {
  background: var(--danger-light);
  color: var(--danger-color);
}
.status-tag.active {
  background: var(--brand-color-light);
  color: var(--brand-color);
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}
.divider .line {
  flex: 1;
  height: 2rpx;
  background: var(--border-color);
}
.divider .text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 安全区适配 */
.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}
