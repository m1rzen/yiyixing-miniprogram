.page {
  min-height: 100vh;
  background: #F5EDE5;
  padding-bottom: 0;
}

/* ══════════════════════════════════
   顶部 Banner
   ══════════════════════════════════ */
.banner {
  position: relative;
  height: 440rpx;
  overflow: hidden;
}
.banner-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, #5C3D2E 0%, #8B6B50 40%, #C8963E 100%);
}
.banner-skyline {
  position: absolute;
  bottom: -10rpx; right: 0;
  width: 70%;
  opacity: 0.18;
}

/* 地址胶囊 */
.addr-pill {
  position: relative; z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin: 110rpx 0 0 32rpx;
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(8px);
  padding: 12rpx 28rpx 12rpx 20rpx;
  border-radius: 100rpx;
}
.addr-text {
  font-size: 24rpx;
  color: #FDF5F0;
  font-weight: 400;
}

/* Banner 标题 */
.banner-titles {
  position: relative; z-index: 2;
  padding: 28rpx 32rpx 0;
}
.banner-title-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}
.banner-highlight {
  font-size: 48rpx;
  font-weight: 800;
  color: #F5E8DF;
  letter-spacing: 4rpx;
}
.banner-brand {
  font-size: 48rpx;
  font-weight: 800;
  color: #C8963E;
  margin-left: 12rpx;
}
.banner-brand-i {
  font-size: 48rpx;
  font-weight: 800;
  color: #FDF5F0;
}
.banner-sub {
  font-size: 26rpx;
  color: rgba(253,245,240,0.7);
  letter-spacing: 6rpx;
  font-weight: 400;
}

/* ══════════════════════════════════
   账单双卡片
   ══════════════════════════════════ */
.bill-cards {
  display: flex;
  gap: 20rpx;
  margin: -64rpx 28rpx 0;
  position: relative; z-index: 5;
}
.bill-card {
  flex: 1;
  background: #FFF;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(92,61,46,0.08);
}
.bill-num {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #3D2B1F;
  line-height: 1.2;
  margin-bottom: 8rpx;
}
.bill-num.accent {
  color: #1D5F8A;
}
.bill-label {
  font-size: 24rpx;
  color: #A09486;
}

/* ══════════════════════════════════
   登录提示条
   ══════════════════════════════════ */
.login-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 28rpx 0;
  padding: 28rpx 32rpx;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(92,61,46,0.04);
}
.login-hint {
  font-size: 28rpx;
  color: #5C3D2E;
  font-weight: 500;
  flex: 1;
}
.login-btn {
  padding: 12rpx 28rpx;
  border: 2rpx solid #C8963E;
  border-radius: 100rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.login-btn-text {
  font-size: 24rpx;
  color: #C8963E;
  font-weight: 600;
}
.login-btn:active { opacity: 0.6; }

/* ══════════════════════════════════
   最新公告
   ══════════════════════════════════ */
.announce-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 24rpx 28rpx 0;
  padding: 24rpx 0;
}
.announce-label {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}
.announce-prefix {
  font-size: 30rpx;
  font-weight: 800;
  color: #3D2B1F;
}
.announce-new {
  font-size: 30rpx;
  font-weight: 800;
  color: #C8963E;
}
.announce-content {
  font-size: 26rpx;
  color: #A09486;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* ══════════════════════════════════
   横幅：邻里互助
   ══════════════════════════════════ */
.promo-banner {
  position: relative;
  margin: 16rpx 28rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  height: 220rpx;
}
.promo-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, #C8963E 0%, #D4A854 50%, #E0BE78 100%);
}
.promo-body {
  position: relative; z-index: 2;
  padding: 32rpx;
}
.promo-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #FFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.promo-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 20rpx;
}
.promo-btn {
  display: inline-block;
  background: rgba(255,255,255,0.92);
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
}
.promo-btn-text {
  font-size: 24rpx;
  color: #8B6B50;
  font-weight: 600;
}
.promo-deco {
  position: absolute;
  right: 24rpx; bottom: 20rpx;
  z-index: 1;
  opacity: 0.9;
}

/* ══════════════════════════════════
   功能网格
   ══════════════════════════════════ */
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 24rpx 28rpx 0;
}
.grid-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFF;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(92,61,46,0.04);
  transition: all 0.15s;
}
.grid-item:active {
  transform: scale(0.97);
  background: #FBF5EF;
}
.grid-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.grid-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2B1F;
  letter-spacing: 2rpx;
}

/* ══════════════════════════════════
   右侧浮动按钮
   ══════════════════════════════════ */
.fab {
  position: fixed;
  right: 20rpx;
  top: 55%;
  z-index: 50;
  background: #FFF;
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 24rpx rgba(92,61,46,0.12);
}
.fab:active { opacity: 0.7; }
.fab-text {
  font-size: 20rpx;
  color: #5C3D2E;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ══════════════════════════════════
   底部固定条
   ══════════════════════════════════ */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 60;
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 16rpx);
  box-shadow: 0 -2rpx 16rpx rgba(92,61,46,0.06);
}
.bottom-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}
.bottom-info {
  flex: 1;
}
.bottom-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.bottom-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #3D2B1F;
}
.free-tag {
  background: #C8963E;
  padding: 2rpx 14rpx;
  border-radius: 100rpx;
}
.free-tag-text {
  font-size: 20rpx;
  color: #FFF;
  font-weight: 600;
}
.bottom-desc {
  font-size: 22rpx;
  color: #A09486;
}
.apply-btn {
  padding: 16rpx 36rpx;
  border: 2rpx solid #C8963E;
  border-radius: 100rpx;
  flex-shrink: 0;
}
.apply-btn:active { opacity: 0.6; }
.apply-btn-text {
  font-size: 26rpx;
  color: #C8963E;
  font-weight: 600;
}

/* 底部占位 */
.bottom-placeholder {
  height: calc(140rpx + env(safe-area-inset-bottom));
}

/* ══════════════════════════════════
   自定义导航栏
   ══════════════════════════════════ */
.custom-nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 100rpx 28rpx 16rpx;
  background: transparent;
}
.nav-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.12); }
.nav-btn:active { background: rgba(255,255,255,0.25); }
.custom-nav .nav-title { font-size: 32rpx; font-weight: 700; color: #FFF; letter-spacing: 4rpx; }

/* ══════════════════════════════════
   账单卡片箭头
   ══════════════════════════════════ */
.bill-card { display: flex; align-items: center; flex-wrap: wrap; }
.bill-num { flex: 1; }
.bill-label { flex: 1; }
.bill-arrow { width: 40rpx; display: flex; align-items: center; }

/* ══════════════════════════════════
   已登录状态栏
   ══════════════════════════════════ */
.logged-in { align-items: center; }
.user-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: linear-gradient(135deg, #C8963E, #A67930); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.user-info { flex: 1; margin-left: 20rpx; }
.user-name { display: block; font-size: 30rpx; color: #3D2B1F; font-weight: 700; }
.user-addr { display: block; font-size: 24rpx; color: #A09486; margin-top: 4rpx; }

/* ══════════════════════════════════
   弹窗通用
   ══════════════════════════════════ */
.popup-card { background: #FFF; border-radius: 32rpx 32rpx 0 0; padding: 0 36rpx calc(env(safe-area-inset-bottom) + 32rpx); }
.popup-header { display: flex; align-items: center; justify-content: space-between; padding: 40rpx 0 24rpx; border-bottom: 2rpx solid #EDE4DB; }
.popup-title { font-size: 36rpx; font-weight: 800; color: #3D2B1F; }
.popup-close { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #A09486; background: #F5EDE5; border-radius: 50%; }
.popup-close:active { background: #EDE4DB; }
.popup-body { padding: 28rpx 0; }
.popup-desc { display: block; font-size: 28rpx; color: #A09486; margin-bottom: 28rpx; }
.popup-submit-btn { background: linear-gradient(135deg, #C8963E, #A67930); height: 92rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; margin-top: 24rpx; }
.popup-submit-btn:active { opacity: 0.8; }
.popup-submit-text { font-size: 32rpx; color: #FFF; font-weight: 700; letter-spacing: 4rpx; }

/* ── 登录弹窗 ── */
.wechat-auth-btn { width: 100%; height: 92rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; background: #07C160; color: #FFF; font-size: 32rpx; font-weight: 600; border-radius: 20rpx; border: none; margin: 0 0 20rpx; box-shadow: 0 8rpx 20rpx rgba(7,193,96,0.2); }
.wechat-auth-btn::after { border: none; }
.wechat-auth-btn:active { opacity: 0.85; }
.phone-login-entry { text-align: center; padding: 16rpx 0; }
.phone-link { font-size: 28rpx; color: #C8963E; font-weight: 500; }
.phone-form { margin-top: 20rpx; }
.phone-input { height: 88rpx; background: #F5EDE5; border-radius: 16rpx; padding: 0 24rpx; font-size: 30rpx; color: #3D2B1F; margin-bottom: 20rpx; box-sizing: border-box; }
.code-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.code-input { flex: 1; }
.code-btn { width: 200rpx; height: 88rpx; background: #C8963E; color: #FFF; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: 600; }
.code-btn.disabled { background: #D4C4B0; }
.code-btn:active:not(.disabled) { opacity: 0.8; }
.phone-submit-btn { background: linear-gradient(135deg, #C8963E, #A67930); height: 92rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; }
.phone-submit-btn:active { opacity: 0.8; }
.phone-submit-btn text { font-size: 32rpx; color: #FFF; font-weight: 700; }

/* ── 认证表单 ── */
.auth-form { margin-bottom: 8rpx; }
.auth-field { margin-bottom: 24rpx; }
.auth-label { display: block; font-size: 28rpx; color: #3D2B1F; font-weight: 600; margin-bottom: 12rpx; }
.auth-input { height: 88rpx; background: #F5EDE5; border-radius: 16rpx; padding: 0 24rpx; font-size: 30rpx; color: #3D2B1F; box-sizing: border-box; }

/* ── 公告详情 ── */
.announce-item { margin-bottom: 28rpx; padding-bottom: 28rpx; border-bottom: 2rpx solid #EDE4DB; }
.announce-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.announce-item-tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 8rpx; background: #C8963E; font-size: 22rpx; color: #FFF; font-weight: 600; margin-bottom: 12rpx; }
.announce-item-tag.old { background: #A09486; }
.announce-item-title { display: block; font-size: 32rpx; color: #3D2B1F; font-weight: 700; margin-bottom: 8rpx; }
.announce-item-date { display: block; font-size: 24rpx; color: #A09486; margin-bottom: 16rpx; }
.announce-item-content { font-size: 28rpx; color: #6B5E50; line-height: 1.7; }

/* ── 邻里互助 ── */
.neighbor-desc { font-size: 28rpx; color: #6B5E50; line-height: 1.7; margin-bottom: 24rpx; }
.neighbor-list { margin-bottom: 16rpx; }
.neighbor-item { display: flex; align-items: center; gap: 24rpx; padding: 24rpx 0; border-bottom: 2rpx solid #EDE4DB; }
.neighbor-item:last-child { border-bottom: none; }
.neighbor-icon { width: 72rpx; height: 72rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.neighbor-info { flex: 1; }
.neighbor-title { display: block; font-size: 30rpx; color: #3D2B1F; font-weight: 600; margin-bottom: 4rpx; }
.neighbor-meta { font-size: 24rpx; color: #A09486; }

/* ── 申请开通 ── */
.apply-type-row { display: flex; gap: 16rpx; }
.type-chip { padding: 16rpx 28rpx; background: #F5EDE5; border-radius: 100rpx; font-size: 28rpx; color: #6B5E50; font-weight: 500; }
.type-chip.active { background: linear-gradient(135deg, #C8963E, #A67930); color: #FFF; }
.type-chip:active { opacity: 0.7; }

/* ── 账单详情 ── */
.bill-detail-card { background: #F5EDE5; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; }
.bill-detail-title { display: block; font-size: 30rpx; color: #3D2B1F; font-weight: 700; margin-bottom: 20rpx; }
.bill-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 2rpx solid #EDE4DB; }
.bill-row:last-child { border-bottom: none; }
.bill-row.total { margin-top: 8rpx; }
.bill-row.total .bill-row-label { font-weight: 700; }
.bill-row.total .bill-row-value { font-weight: 800; font-size: 34rpx; color: #C8963E; }
.bill-row-label { font-size: 28rpx; color: #6B5E50; }
.bill-row-value { font-size: 28rpx; color: #3D2B1F; font-weight: 600; }
.bill-row-value.green { color: #2D8B6F; }
.bill-row-value.red { color: #C94545; }
.bill-empty-hint { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 24rpx 0; font-size: 26rpx; color: #A09486; }
