.page {
  min-height: 100vh;
  background: #F5EDE5;
  padding-bottom: 0;
}

/* ══════════════════════════════════
   顶部 Banner
   ══════════════════════════════════ */
.banner {
  position: relative;
  height: 440rpx;
  overflow: hidden;
}
.banner-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, #5C3D2E 0%, #8B6B50 40%, #C8963E 100%);
}
.banner-skyline {
  position: absolute;
  bottom: -10rpx; right: 0;
  width: 70%;
  opacity: 0.18;
}

/* 地址胶囊 */
.addr-pill {
  position: relative; z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin: 110rpx 0 0 32rpx;
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(8px);
  padding: 12rpx 28rpx 12rpx 20rpx;
  border-radius: 100rpx;
}
.addr-text {
  font-size: 24rpx;
  color: #FDF5F0;
  font-weight: 400;
}

/* Banner 标题 */
.banner-titles {
  position: relative; z-index: 2;
  padding: 28rpx 32rpx 0;
}
.banner-title-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}
.banner-highlight {
  font-size: 48rpx;
  font-weight: 800;
  color: #F5E8DF;
  letter-spacing: 4rpx;
}
.banner-brand {
  font-size: 48rpx;
  font-weight: 800;
  color: #C8963E;
  margin-left: 12rpx;
}
.banner-brand-i {
  font-size: 48rpx;
  font-weight: 800;
  color: #FDF5F0;
}
.banner-sub {
  font-size: 26rpx;
  color: rgba(253,245,240,0.7);
  letter-spacing: 6rpx;
  font-weight: 400;
}

/* ══════════════════════════════════
   账单双卡片
   ══════════════════════════════════ */
.bill-cards {
  display: flex;
  gap: 20rpx;
  margin: -64rpx 28rpx 0;
  position: relative; z-index: 5;
}
.bill-card {
  flex: 1;
  background: #FFF;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(92,61,46,0.08);
}
.bill-num {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #3D2B1F;
  line-height: 1.2;
  margin-bottom: 8rpx;
}
.bill-num.accent {
  color: #1D5F8A;
}
.bill-label {
  font-size: 24rpx;
  color: #A09486;
}

/* ══════════════════════════════════
   登录提示条
   ══════════════════════════════════ */
.login-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 28rpx 0;
  padding: 28rpx 32rpx;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(92,61,46,0.04);
}
.login-hint {
  font-size: 28rpx;
  color: #5C3D2E;
  font-weight: 500;
  flex: 1;
}
.login-btn {
  padding: 12rpx 28rpx;
  border: 2rpx solid #C8963E;
  border-radius: 100rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.login-btn-text {
  font-size: 24rpx;
  color: #C8963E;
  font-weight: 600;
}
.login-btn:active { opacity: 0.6; }

/* ══════════════════════════════════
   最新公告
   ══════════════════════════════════ */
.announce-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 24rpx 28rpx 0;
  padding: 24rpx 0;
}
.announce-label {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}
.announce-prefix {
  font-size: 30rpx;
  font-weight: 800;
  color: #3D2B1F;
}
.announce-new {
  font-size: 30rpx;
  font-weight: 800;
  color: #C8963E;
}
.announce-content {
  font-size: 26rpx;
  color: #A09486;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* ══════════════════════════════════
   横幅：邻里互助
   ══════════════════════════════════ */
.promo-banner {
  position: relative;
  margin: 16rpx 28rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  height: 220rpx;
}
.promo-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, #C8963E 0%, #D4A854 50%, #E0BE78 100%);
}
.promo-body {
  position: relative; z-index: 2;
  padding: 32rpx;
}
.promo-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #FFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.promo-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 20rpx;
}
.promo-btn {
  display: inline-block;
  background: rgba(255,255,255,0.92);
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
}
.promo-btn-text {
  font-size: 24rpx;
  color: #8B6B50;
  font-weight: 600;
}
.promo-deco {
  position: absolute;
  right: 24rpx; bottom: 20rpx;
  z-index: 1;
  opacity: 0.9;
}

/* ══════════════════════════════════
   功能网格
   ══════════════════════════════════ */
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 24rpx 28rpx 0;
}
.grid-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFF;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(92,61,46,0.04);
  transition: all 0.15s;
}
.grid-item:active {
  transform: scale(0.97);
  background: #FBF5EF;
}
.grid-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.grid-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2B1F;
  letter-spacing: 2rpx;
}

/* ══════════════════════════════════
   右侧浮动按钮
   ══════════════════════════════════ */
.fab {
  position: fixed;
  right: 20rpx;
  top: 55%;
  z-index: 50;
  background: #FFF;
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 24rpx rgba(92,61,46,0.12);
}
.fab:active { opacity: 0.7; }
.fab-text {
  font-size: 20rpx;
  color: #5C3D2E;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ══════════════════════════════════
   底部固定条
   ══════════════════════════════════ */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 60;
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 16rpx);
  box-shadow: 0 -2rpx 16rpx rgba(92,61,46,0.06);
}
.bottom-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}
.bottom-info {
  flex: 1;
}
.bottom-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.bottom-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #3D2B1F;
}
.free-tag {
  background: #C8963E;
  padding: 2rpx 14rpx;
  border-radius: 100rpx;
}
.free-tag-text {
  font-size: 20rpx;
  color: #FFF;
  font-weight: 600;
}
.bottom-desc {
  font-size: 22rpx;
  color: #A09486;
}
.apply-btn {
  padding: 16rpx 36rpx;
  border: 2rpx solid #C8963E;
  border-radius: 100rpx;
  flex-shrink: 0;
}
.apply-btn:active { opacity: 0.6; }
.apply-btn-text {
  font-size: 26rpx;
  color: #C8963E;
  font-weight: 600;
}

/* 底部占位 */
.bottom-placeholder {
  height: calc(140rpx + env(safe-area-inset-bottom));
}
