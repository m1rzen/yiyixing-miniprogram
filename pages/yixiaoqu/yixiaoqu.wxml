<view class="page">

  <!-- 自定义导航栏 -->
  <view class="custom-nav">
    <view class="nav-btn" bindtap="goHome"><t-icon name="home" size="36rpx" color="#FFF" /></view>
    <text class="nav-title">邑小区</text>
    <view class="nav-btn" bindtap="goHome"><t-icon name="home" size="36rpx" color="transparent" /></view>
  </view>

  <!-- ====== 顶部 Banner ====== -->
  <view class="banner">
    <view class="banner-bg"></view>
    <image class="banner-skyline" src="../entry/skyline.svg" mode="widthFix" />
    <view class="addr-pill" bindtap="showCommunityPicker">
      <t-icon name="location" size="28rpx" color="#FDF5F0" />
      <text class="addr-text">{{userAddr || '暂无房屋信息'}}</text>
      <t-icon name="chevron-down" size="24rpx" color="#FDF5F0" wx:if="{{isLoggedIn && communityList.length > 1}}" />
    </view>
    <view class="banner-titles">
      <view class="banner-title-row">
        <text class="banner-highlight">侨乡引领</text>
        <text class="banner-brand"> 邑</text>
        <text class="banner-brand-i">小区</text>
      </view>
      <text class="banner-sub">共建共治共享</text>
    </view>
  </view>

  <!-- ====== 账单双卡片 ====== -->
  <view class="bill-cards">
    <view class="bill-card" bindtap="goBill">
      <text class="bill-num">0.00</text>
      <text class="bill-label">本月账单（元）</text>
      <view class="bill-arrow"><t-icon name="chevron-right" size="28rpx" color="#A09486" /></view>
    </view>
    <view class="bill-card" bindtap="goBill">
      <text class="bill-num accent">0.00</text>
      <text class="bill-label">共有资金余额（元）</text>
      <view class="bill-arrow"><t-icon name="chevron-right" size="28rpx" color="#A09486" /></view>
    </view>
  </view>

  <!-- ====== 登录提示条 ====== -->
  <view class="login-bar" wx:if="{{!isLoggedIn}}">
    <text class="login-hint">仅限小区已登记住户使用，请登录</text>
    <view class="login-btn" bindtap="showLoginPopup">
      <text class="login-btn-text">去登录 ></text>
    </view>
  </view>
  <!-- 已登录状态 -->
  <view class="login-bar logged-in" wx:else>
    <view class="user-avatar">
      <t-icon name="user" size="36rpx" color="#FFF" />
    </view>
    <view class="user-info">
      <text class="user-name">{{userName || '住户用户'}}</text>
      <text class="user-addr">{{userAddr || '暂未绑定房屋'}}</text>
    </view>
    <view class="login-btn logout-btn" bindtap="handleLogout">
      <text class="login-btn-text" style="color:#A09486;border-color:#D4C4B0;">退出</text>
    </view>
  </view>

  <!-- ====== 最新公告 ====== -->
  <view class="announce-bar" bindtap="showAnnounceDetail">
    <view class="announce-label">
      <text class="announce-prefix">最</text>
      <text class="announce-new">新</text>
      <text class="announce-prefix">公告</text>
    </view>
    <t-icon name="sound" size="32rpx" color="#B8956F" />
    <text class="announce-content">{{latestAnnounce ? latestAnnounce.title : '欢迎使用邑小区智慧社区平台'}}</text>
    <t-icon name="chevron-right" size="28rpx" color="#D4C4B0" />
  </view>

  <!-- ====== 横幅：邻里互助 ====== -->
  <view class="promo-banner" bindtap="showNeighborDetail">
    <view class="promo-bg"></view>
    <view class="promo-body">
      <text class="promo-title">邻里互助队</text>
      <text class="promo-desc">守望相助，共建家园</text>
      <view class="promo-btn"><text class="promo-btn-text">了解加入</text></view>
    </view>
    <view class="promo-deco"><t-icon name="usergroup" size="100rpx" color="rgba(255,255,255,0.35)" /></view>
  </view>

  <!-- ====== 功能网格 ====== -->
  <view class="grid">
    <view class="grid-item" wx:for="{{features}}" wx:key="key" bindtap="goFeature" data-key="{{item.key}}">
      <view class="grid-icon" style="background: {{item.bg}};">
        <t-icon name="{{item.icon}}" size="44rpx" color="#FFF" />
      </view>
      <text class="grid-label">{{item.title}}</text>
    </view>
  </view>

  <!-- ====== 右侧浮动按钮 ====== -->
  <view class="fab" bindtap="showAuthPopup">
    <t-icon name="user-checked" size="48rpx" color="#5C3D2E" />
    <text class="fab-text">住户认证</text>
  </view>

  <!-- ====== 底部固定条 ====== -->
  <view class="bottom-bar">
    <view class="bottom-left" bindtap="showApplyPopup">
      <t-icon name="edit-1" size="40rpx" color="#C8963E" />
      <view class="bottom-info">
        <view class="bottom-title-row">
          <text class="bottom-title">申请开通邑小区</text>
          <view class="free-tag"><text class="free-tag-text">免费</text></view>
        </view>
        <text class="bottom-desc">业委会/物业公司/社区(居委会)可申请</text>
      </view>
    </view>
    <view class="apply-btn" bindtap="showApplyPopup">
      <text class="apply-btn-text">去申请</text>
    </view>
  </view>

  <view class="bottom-placeholder"></view>

  <!-- ====== 弹窗：登录 ====== -->
  <t-popup visible="{{loginPopupVisible}}" placement="bottom" bind:close="hideLoginPopup">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">住户登录</text>
        <text class="popup-close" bindtap="hideLoginPopup">✕</text>
      </view>
      <view class="popup-body">
        <text class="popup-desc">登录后可使用物业缴费、诉求建议等全部功能</text>
        <button class="wechat-auth-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhone">
          <t-icon name="logo-wechatpay" size="36rpx" color="#FFF" />
          <text>微信手机号快捷登录</text>
        </button>
        <view class="phone-login-entry" bindtap="switchToPhoneLogin">
          <text class="phone-link">手机号验证码登录</text>
        </view>
        <block wx:if="{{phoneLoginMode}}">
          <view class="phone-form">
            <input class="phone-input" type="number" placeholder="请输入手机号" bindinput="onPhoneInput" maxlength="11" />
            <view class="code-row">
              <input class="phone-input code-input" type="number" placeholder="验证码" bindinput="onCodeInput" maxlength="6" />
              <view class="code-btn {{codeCooldown > 0 ? 'disabled' : ''}}" bindtap="sendCode">
                <text>{{codeCooldown > 0 ? codeCooldown + 's' : '获取验证码'}}</text>
              </view>
            </view>
            <view class="phone-submit-btn" bindtap="doPhoneLogin"><text>登录</text></view>
          </view>
        </block>
      </view>
    </view>
  </t-popup>

  <!-- ====== 弹窗：住户认证 ====== -->
  <t-popup visible="{{authPopupVisible}}" placement="bottom" bind:close="hideAuthPopup">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">住户认证</text>
        <text class="popup-close" bindtap="hideAuthPopup">✕</text>
      </view>
      <view class="popup-body">
        <text class="popup-desc">认证后可使用缴费、投票等核心功能</text>
        <view class="auth-form">
          <view class="auth-field">
            <text class="auth-label">所属小区</text>
            <picker mode="selector" range="{{communityNames}}" value="{{authCommunityIdx}}" bindchange="onAuthCommunityChange">
              <view class="picker-box">
                <text class="picker-text">{{authCommunityName || '请选择小区'}}</text>
                <t-icon name="chevron-right" size="28rpx" color="#A09486" />
              </view>
            </picker>
          </view>
          <view class="auth-field">
            <text class="auth-label">真实姓名</text>
            <input class="auth-input" placeholder="请输入姓名" bindinput="onAuthInput" data-key="name" />
          </view>
          <view class="auth-field">
            <text class="auth-label">楼栋房号</text>
            <input class="auth-input" placeholder="如：3栋2单元501" bindinput="onAuthInput" data-key="room" />
          </view>
          <view class="auth-field">
            <text class="auth-label">身份证号</text>
            <input class="auth-input" placeholder="请输入18位身份证号" bindinput="onAuthInput" data-key="idcard" maxlength="18" />
          </view>
        </view>
        <view class="popup-submit-btn" bindtap="submitAuth"><text class="popup-submit-text">提交认证</text></view>
      </view>
    </view>
  </t-popup>

  <!-- ====== 弹窗：公告详情 ====== -->
  <t-popup visible="{{announcePopupVisible}}" placement="bottom" bind:close="hideAnnounceDetail">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">最新公告</text>
        <text class="popup-close" bindtap="hideAnnounceDetail">✕</text>
      </view>
      <view class="popup-body announce-body">
        <!-- 云端公告数据 -->
        <block wx:if="{{latestAnnounce}}">
          <view class="announce-item" bindtap="hideAnnounceDetail">
            <view class="announce-item-tag">公告</view>
            <text class="announce-item-title">{{latestAnnounce.title}}</text>
            <text class="announce-item-date">{{latestAnnounce.createdAt || latestAnnounce.date || ''}}</text>
            <text class="announce-item-content">{{latestAnnounce.content || latestAnnounce.summary || ''}}</text>
          </view>
        </block>
        <!-- 降级默认公告 -->
        <block wx:else>
          <view class="announce-item" bindtap="hideAnnounceDetail">
            <view class="announce-item-tag">公告</view>
            <text class="announce-item-title">欢迎使用邑小区智慧社区平台</text>
            <text class="announce-item-date">2026-04-18</text>
            <text class="announce-item-content">邑小区智慧社区平台正式上线！业主可通过本平台进行物业缴费、诉求建议、议事协商、信息查询等操作。如有疑问请联系物业服务中心。</text>
          </view>
          <view class="announce-item">
            <view class="announce-item-tag old">通知</view>
            <text class="announce-item-title">关于小区门禁系统升级的通知</text>
            <text class="announce-item-date">2026-04-15</text>
            <text class="announce-item-content">为提升小区安全管理水平，物业将于近期对门禁系统进行全面升级，届时请各位业主配合登记人脸信息。</text>
          </view>
        </block>
      </view>
    </view>
  </t-popup>

  <!-- ====== 弹窗：邻里互助 ====== -->
  <t-popup visible="{{neighborPopupVisible}}" placement="bottom" bind:close="hideNeighborDetail">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">邻里互助队</text>
        <text class="popup-close" bindtap="hideNeighborDetail">✕</text>
      </view>
      <view class="popup-body neighbor-body">
        <text class="neighbor-desc">邻里互助队由小区热心居民自发组成，旨在增进邻里感情，守望相助，共建和谐社区。</text>
        <view class="neighbor-list">
          <view class="neighbor-item">
            <view class="neighbor-icon" style="background:linear-gradient(135deg,#C8963E,#A67930)"><t-icon name="tools" size="36rpx" color="#FFF" /></view>
            <view class="neighbor-info"><text class="neighbor-title">维修帮手</text><text class="neighbor-meta">水电维修、家具简单修理</text></view>
          </view>
          <view class="neighbor-item">
            <view class="neighbor-icon" style="background:linear-gradient(135deg,#2D8B6F,#1E6B52)"><t-icon name="cart" size="36rpx" color="#FFF" /></view>
            <view class="neighbor-info"><text class="neighbor-title">代购跑腿</text><text class="neighbor-meta">老人日用品代购、快递代收</text></view>
          </view>
          <view class="neighbor-item">
            <view class="neighbor-icon" style="background:linear-gradient(135deg,#1D5F8A,#134566)"><t-icon name="notification" size="36rpx" color="#FFF" /></view>
            <view class="neighbor-info"><text class="neighbor-title">应急互助</text><text class="neighbor-meta">突发情况互助、紧急联络</text></view>
          </view>
          <view class="neighbor-item">
            <view class="neighbor-icon" style="background:linear-gradient(135deg,#D4A08A,#B8856A)"><t-icon name="heart-filled" size="36rpx" color="#FFF" /></view>
            <view class="neighbor-info"><text class="neighbor-title">关爱陪伴</text><text class="neighbor-meta">独居老人探访、陪伴聊天</text></view>
          </view>
        </view>
        <view class="popup-submit-btn" bindtap="joinNeighbor"><text class="popup-submit-text">申请加入互助队</text></view>
      </view>
    </view>
  </t-popup>

  <!-- ====== 弹窗：申请开通 ====== -->
  <t-popup visible="{{applyPopupVisible}}" placement="bottom" bind:close="hideApplyPopup">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">申请开通邑小区</text>
        <text class="popup-close" bindtap="hideApplyPopup">✕</text>
      </view>
      <view class="popup-body">
        <text class="popup-desc">业委会、物业公司或社区（居委会）可申请开通</text>
        <view class="apply-form">
          <view class="auth-field">
            <text class="auth-label">申请单位</text>
            <input class="auth-input" placeholder="请输入单位全称" bindinput="onApplyInput" data-key="org" />
          </view>
          <view class="auth-field">
            <text class="auth-label">负责人姓名</text>
            <input class="auth-input" placeholder="请输入负责人姓名" bindinput="onApplyInput" data-key="name" />
          </view>
          <view class="auth-field">
            <text class="auth-label">联系电话</text>
            <input class="auth-input" type="number" placeholder="请输入联系电话" bindinput="onApplyInput" data-key="phone" maxlength="11" />
          </view>
          <view class="auth-field">
            <text class="auth-label">申请类型</text>
            <view class="apply-type-row">
              <view class="type-chip {{applyType === 'committee' ? 'active' : ''}}" bindtap="setApplyType" data-type="committee"><text>业委会</text></view>
              <view class="type-chip {{applyType === 'property' ? 'active' : ''}}" bindtap="setApplyType" data-type="property"><text>物业公司</text></view>
              <view class="type-chip {{applyType === 'community' ? 'active' : ''}}" bindtap="setApplyType" data-type="community"><text>居委会</text></view>
            </view>
          </view>
        </view>
        <view class="popup-submit-btn" bindtap="submitApply"><text class="popup-submit-text">提交申请</text></view>
      </view>
    </view>
  </t-popup>

  <!-- ====== 弹窗：账单详情 ====== -->
  <t-popup visible="{{billPopupVisible}}" placement="bottom" bind:close="hideBill">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">账单明细</text>
        <text class="popup-close" bindtap="hideBill">✕</text>
      </view>
      <view class="popup-body">
        <view class="bill-detail-card">
          <text class="bill-detail-title">本月账单</text>
          <view class="bill-row"><text class="bill-row-label">物业费</text><text class="bill-row-value">¥0.00（未出账）</text></view>
          <view class="bill-row"><text class="bill-row-label">水费</text><text class="bill-row-value">¥0.00（未出账）</text></view>
          <view class="bill-row"><text class="bill-row-label">电费</text><text class="bill-row-value">¥0.00（未出账）</text></view>
          <view class="bill-row"><text class="bill-row-label">燃气费</text><text class="bill-row-value">¥0.00（未出账）</text></view>
          <view class="bill-row total"><text class="bill-row-label">合计</text><text class="bill-row-value">¥0.00</text></view>
        </view>
        <view class="bill-detail-card">
          <text class="bill-detail-title">共有资金</text>
          <view class="bill-row"><text class="bill-row-label">本期收入</text><text class="bill-row-value green">+¥0.00</text></view>
          <view class="bill-row"><text class="bill-row-label">本期支出</text><text class="bill-row-value red">-¥0.00</text></view>
          <view class="bill-row"><text class="bill-row-label">累计结余</text><text class="bill-row-value">¥0.00</text></view>
        </view>
        <view class="bill-empty-hint">
          <t-icon name="info-circle" size="40rpx" color="#D4C4B0" />
          <text>当前无待缴费账单</text>
        </view>
      </view>
    </view>
  </t-popup>

  <!-- ====== 弹窗：多小区选择 ====== -->
  <t-popup visible="{{communityPickerVisible}}" placement="bottom" bind:close="hideCommunityPicker">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">选择小区</text>
        <text class="popup-close" bindtap="hideCommunityPicker">✕</text>
      </view>
      <view class="popup-body">
        <view class="comm-item" wx:for="{{communityList}}" wx:key="_id" bindtap="selectCommunity" data-item="{{item}}">
          <text class="comm-item-text">{{item.room}} · {{item.name}}</text>
          <t-icon name="check" size="32rpx" color="#C8963E" wx:if="{{currentCommunityId === item.communityId}}" />
        </view>
      </view>
    </view>
  </t-popup>

  <t-toast id="t-toast" />
</view>
