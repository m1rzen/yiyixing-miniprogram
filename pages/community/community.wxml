<view class="community-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <t-search
      placeholder="搜索小区名称或地址"
      shape="round"
      clearable
      bind:change="onSearch"
    />
  </view>

  <!-- 区域筛选 -->
  <scroll-view class="area-tabs" scroll-x enable-flex>
    <view
      class="area-tab {{areaFilter === item ? 'active' : ''}}"
      wx:for="{{areas}}" wx:key="*this"
      bindtap="onAreaChange" data-area="{{item}}"
    >{{item}}</view>
  </scroll-view>

  <!-- 当前选中 -->
  <view class="current-section" wx:if="{{selectedCommunity && !keyword}}">
    <text class="section-label">当前选择</text>
    <view class="current-item">
      <view class="ci-left">
        <t-icon name="location" size="36rpx" color="#2B6CB0" />
        <text class="ci-name">{{selectedCommunity}}</text>
      </view>
      <t-icon name="check-circle-filled" size="40rpx" color="#2B6CB0" />
    </view>
  </view>

  <!-- 社区列表 -->
  <text class="section-label list-label">{{keyword ? '搜索结果' : '全部小区'}} ({{filteredList.length}})</text>
  <scroll-view class="community-list" scroll-y>
    <view
      class="list-item"
      wx:for="{{filteredList}}" wx:key="id"
      bindtap="handleSelect"
      data-name="{{item.name}}" data-id="{{item.id}}"
      hover-class="item-hover"
    >
      <view class="item-content">
        <view class="item-name-row">
          <text class="item-name {{selectedCommunity === item.name ? 'selected' : ''}}">{{item.name}}</text>
          <view class="item-area-tag" wx:if="{{item.area}}">{{item.area}}</view>
        </view>
        <text class="item-address">{{item.address}}</text>
      </view>
      <t-icon wx:if="{{selectedCommunity === item.name}}" name="check" size="36rpx" color="#2B6CB0" class="check-anim" />
    </view>

    <view class="empty-state" wx:if="{{filteredList.length === 0}}">
      <t-icon name="info-circle" size="80rpx" color="#D1D5DB" />
      <text class="empty-text">未找到相关小区</text>
      <text class="empty-sub">请尝试其他关键词</text>
    </view>
  </scroll-view>
</view>
