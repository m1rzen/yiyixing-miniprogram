<view class="welcome-page">
  <!-- 沉浸式背景 -->
  <view class="bg-gradient"></view>
  <view class="bg-pattern"></view>
  <!-- 碉楼剪影装饰 -->
  <view class="bg-deco-bottom"></view>

  <!-- 品牌区域 -->
  <view class="brand-area {{animReady ? 'anim-in' : ''}}">
    <view class="brand-icon-wrap">
      <view class="brand-icon-inner">
        <t-icon name="secured" size="56rpx" color="#FFF" />
      </view>
    </view>
    <view class="brand-title">邑易行</view>
    <view class="brand-subtitle">
      <view class="subtitle-line"></view>
      <text>江门蓬江 · 智慧社区通行</text>
      <view class="subtitle-line"></view>
    </view>
    <view class="brand-slogan">五邑侨乡 · 安居乐业</view>
  </view>

  <!-- 功能入口卡片 -->
  <view class="entry-card {{animReady ? 'anim-slide-up' : ''}}">
    <view class="entry-header">
      <view class="entry-icon">
        <t-icon name="user-add" size="40rpx" color="#FFF" />
      </view>
      <view class="entry-header-text">
        <text class="entry-title">访客登记通行</text>
        <text class="entry-desc">实名登记 · 智能审核 · 全程可控</text>
      </view>
    </view>

    <t-button block t-class="btn-primary main-btn" bindtap="handleRegister">
      <t-icon name="edit-1" size="36rpx" slot="icon" color="#FFF" />
      立即登记
    </t-button>

    <view class="quick-entry" bindtap="handleQuickPass">
      <t-icon name="qrcode" size="32rpx" color="{{brandColor}}" />
      <text>已有通行证？去亮码通行</text>
      <t-icon name="chevron-right" size="28rpx" color="{{brandColor}}" />
    </view>

    <view class="divider">
      <view class="line"></view>
      <view class="text">其他选项</view>
      <view class="line"></view>
    </view>

    <view class="guard-entry" bindtap="goToGuardLogin">
      <view class="guard-icon-wrap">
        <t-icon name="user-safety" size="32rpx" color="#FFF" />
      </view>
      <text class="guard-entry-text">保安端登录</text>
      <t-icon name="chevron-right" size="28rpx" color="#9CA3AF" />
    </view>
  </view>

  <!-- 授权登录弹窗 -->
  <t-popup visible="{{popupVisible}}" bind:visible-change="onVisibleChange" placement="bottom" close-btn>
    <view class="auth-popup">
      <view class="auth-popup-header">
        <view class="auth-icon-wrap">
          <t-icon name="lock-on" size="48rpx" color="{{brandColor}}" />
        </view>
        <text class="auth-title">身份授权</text>
        <text class="auth-desc">为保障社区安全，我们需要验证您的身份信息</text>
      </view>

      <!-- 微信手机号快捷授权（原生 button） -->
      <button class="wechat-auth-btn {{!isAgreed ? 'disabled' : ''}}"
              open-type="{{isAgreed ? 'getPhoneNumber' : ''}}"
              bindgetphonenumber="onGetPhoneNumber"
              bindtap="{{isAgreed ? '' : 'onAuthNotAgreed'}}">
        <t-icon name="logo-wechat" size="36rpx" color="#FFF" />
        <text>微信手机号快捷授权</text>
      </button>

      <t-button block variant="outline" t-class="phone-btn" bindtap="goToPhoneLogin">
        手机号验证码登录
      </t-button>

      <view class="agreement-row">
        <t-checkbox checked="{{isAgreed}}" bind:change="onAgreeChange" borderless />
        <view class="agreement-text">
          我已阅读并同意<text class="link" catchtap="openPrivacy">《邑易行隐私保护指引》</text>
        </view>
      </view>
    </view>
  </t-popup>

  <!-- 头像选择弹窗 -->
  <t-popup visible="{{avatarVisible}}" placement="bottom" round>
    <view class="avatar-popup">
      <view class="avatar-popup-header">
        <view class="avatar-success-icon">
          <t-icon name="check-circle-filled" size="48rpx" color="#07C160" />
        </view>
        <text class="avatar-popup-title">手机号授权成功</text>
        <text class="avatar-popup-phone">{{authPhone}}</text>
      </view>
      <view class="avatar-popup-body">
        <text class="avatar-popup-desc">选择一个头像，作为您在邑易行的个人形象</text>
        <view class="avatar-preview-wrap">
          <image wx:if="{{tempAvatarUrl}}" class="avatar-preview-img" src="{{tempAvatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-preview-placeholder">
            <t-icon name="user" size="60rpx" color="#D1D5DB" />
          </view>
        </view>
        <button class="avatar-choose-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          选择微信头像
        </button>
      </view>
      <view class="avatar-popup-footer">
        <button class="avatar-confirm-btn" bindtap="confirmLogin">
          {{tempAvatarUrl ? '确认并登录' : '跳过，直接登录'}}
        </button>
      </view>
    </view>
  </t-popup>

  <!-- 手机号登录弹窗 -->
  <t-popup visible="{{phoneLoginVisible}}" placement="bottom" close-btn bind:visible-change="onPhoneLoginClose">
    <view class="phone-popup">
      <view class="popup-title">手机号登录</view>
      <view class="form-group">
        <text class="form-label">手机号码</text>
        <input class="form-input" placeholder="请输入11位手机号码" type="number" maxlength="11" value="{{phoneNumber}}" bindinput="onPhoneInput" />
      </view>
      <view class="form-group">
        <text class="form-label">验证码</text>
        <view class="code-row">
          <input class="form-input code-input" placeholder="请输入6位验证码" type="number" maxlength="6" value="{{verifyCode}}" bindinput="onCodeInput" />
          <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="handleGetCode">
            {{countdown > 0 ? countdown + 's' : '获取验证码'}}
          </view>
        </view>
      </view>
      <t-button block t-class="btn-primary" bindtap="handlePhoneSubmit" style="margin-top: 60rpx;">
        验证并登录
      </t-button>
    </view>
  </t-popup>

  <!-- 隐私弹窗 -->
  <t-popup visible="{{privacyVisible}}" bind:visible-change="onPrivacyVisibleChange" placement="center">
    <view class="privacy-popup">
      <view class="privacy-header">邑易行隐私保护指引</view>
      <scroll-view scroll-y class="privacy-scroll">
        <view class="privacy-section">
          <view class="privacy-section-title">1. 信息收集</view>
          <view class="privacy-section-text">为提供访客登记与核验服务，保障社区安全，我们将收集您的必要个人信息，包括但不限于手机号码、身份证明信息以及拜访记录等。所有信息均通过加密传输和存储。</view>
        </view>
        <view class="privacy-section">
          <view class="privacy-section-title">2. 信息使用</view>
          <view class="privacy-section-text">您的个人信息将严格仅用于江门市蓬江区各接入社区的安全核验、通行赋码及必要的物业管理服务。我们承诺不会将其用于商业营销或其他无关用途。</view>
        </view>
        <view class="privacy-section">
          <view class="privacy-section-title">3. 位置信息（重要）</view>
          <view class="privacy-section-text">
            <text class="privacy-highlight">根据社区安全管理规定，外来人员审核通过入场后，系统将强制自动开启位置追踪功能，每3分钟采集一次位置信息，用于实时安全管控。该功能在入场期间不可手动关闭，直至您完成签退操作后自动停止。</text>
            位置数据仅供社区安保人员查看，用于保障小区公共安全。数据将在30天后自动清除。
          </view>
        </view>
        <view class="privacy-section">
          <view class="privacy-section-title">4. 信息安全</view>
          <view class="privacy-section-text">我们采用业界标准的安全防护措施保护您的个人信息，包括数据加密、访问控制和安全审计等。仅经授权的社区管理人员可查看相关信息。</view>
        </view>
        <view class="privacy-section">
          <view class="privacy-section-title">5. 用户权利</view>
          <view class="privacy-section-text">您有权查看、修改或删除您的个人信息。如有任何疑问，请联系所在社区物业管理处。</view>
        </view>
      </scroll-view>
      <view class="privacy-footer">
        <t-button block t-class="btn-primary" bindtap="closePrivacy">我已了解并同意</t-button>
      </view>
    </view>
  </t-popup>

  <t-toast id="t-toast" />
</view>
