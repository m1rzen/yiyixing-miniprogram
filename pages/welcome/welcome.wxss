.welcome-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ========== 背景层 ========== */
.bg-gradient {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(170deg, #0C2E45 0%, #1D5F8A 30%, #134566 60%, #0A2538 100%);
  z-index: 1;
}
.bg-pattern {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 2; opacity: 0.04;
  background-image:
    radial-gradient(circle at 25% 25%, #FFF 1px, transparent 1px),
    radial-gradient(circle at 75% 75%, #FFF 1px, transparent 1px);
  background-size: 60px 60px;
}
/* 底部碉楼剪影装饰 */
.bg-deco-bottom {
  position: fixed;
  bottom: 0; left: 0;
  width: 100%; height: 200rpx;
  z-index: 2;
  opacity: 0.06;
  background:
    linear-gradient(to top, rgba(200,150,62,0.3), transparent 60%),
    /* 碉楼剪影用梯形模拟 */
    linear-gradient(0deg, #FFF 40rpx, transparent 40rpx),
    linear-gradient(0deg, #FFF 80rpx, transparent 80rpx);
  background-size: 100% 100%, 60rpx 100rpx, 40rpx 100rpx;
  background-position: center, 15% bottom, 75% bottom;
  background-repeat: no-repeat, no-repeat, no-repeat;
}

/* ========== 品牌区域 ========== */
.brand-area {
  position: relative; z-index: 3;
  padding: 180rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transform: translateY(40rpx);
  transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.brand-area.anim-in {
  opacity: 1;
  transform: translateY(0);
}

.brand-icon-wrap {
  width: 128rpx; height: 128rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(200,150,62,0.3) 0%, rgba(255,255,255,0.1) 100%);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border: 2rpx solid rgba(200,150,62,0.25);
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.25);
}
.brand-icon-inner {
  width: 96rpx; height: 96rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-title {
  font-size: 76rpx;
  font-weight: 800;
  color: #FFF;
  letter-spacing: 12rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}

.brand-subtitle {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}
.subtitle-line {
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(200,150,62,0.6), transparent);
}

.brand-slogan {
  font-size: 24rpx;
  color: rgba(200,150,62,0.7);
  letter-spacing: 8rpx;
  font-weight: 500;
}

/* ========== 功能入口卡片 ========== */
.entry-card {
  position: relative; z-index: 3;
  margin: auto 0 0;
  background: #FFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 52rpx 44rpx calc(env(safe-area-inset-bottom) + 36rpx);
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.12);
  opacity: 0;
  transform: translateY(60rpx);
  transition: all 0.8s 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.entry-card.anim-slide-up {
  opacity: 1;
  transform: translateY(0);
}

.entry-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 36rpx;
}
.entry-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 20rpx;
  background: var(--brand-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-brand);
}
.entry-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}
.entry-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4rpx;
}

.main-btn {
  height: 100rpx !important;
  border-radius: 24rpx !important;
  font-size: 34rpx !important;
}

.quick-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--brand-color);
  font-weight: 500;
}
.quick-entry:active { opacity: 0.7; }

.guard-entry {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  margin-top: 8rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
}
.guard-icon-wrap {
  width: 52rpx; height: 52rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #4A5568, #2D3748);
  display: flex;
  align-items: center;
  justify-content: center;
}
.guard-entry-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
.guard-entry:active { background: var(--bg-hover); }

/* ========== 授权弹窗 ========== */
.auth-popup {
  padding: 52rpx 44rpx calc(env(safe-area-inset-bottom) + 40rpx);
  background: #FFF;
  border-radius: 40rpx 40rpx 0 0;
}
.auth-popup-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 44rpx;
}
.auth-icon-wrap {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  background: var(--brand-color-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.auth-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.auth-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}

.wechat-btn {
  background: #07C160 !important;
  color: #FFF !important;
  height: 96rpx !important;
  border-radius: var(--radius-lg) !important;
  font-size: 32rpx !important;
  border: none !important;
  margin-bottom: 20rpx !important;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.20) !important;
}
.phone-btn {
  color: var(--brand-color) !important;
  border-color: var(--brand-color) !important;
  height: 96rpx !important;
  border-radius: var(--radius-lg) !important;
  font-size: 30rpx !important;
  margin-bottom: 32rpx !important;
  background: var(--brand-color-light) !important;
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.agreement-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex: 1;
}
.link {
  color: var(--brand-color);
  font-weight: 500;
}

/* ========== 手机号弹窗 ========== */
.phone-popup {
  padding: 52rpx 44rpx calc(env(safe-area-inset-bottom) + 40rpx);
  background: #FFF;
  border-radius: 40rpx 40rpx 0 0;
}
.popup-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 44rpx;
}
.form-group { margin-bottom: 32rpx; }
.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}
.form-input {
  height: 96rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 0 30rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.form-input:focus {
  border-color: var(--brand-color);
  background: #FFF;
}
.code-row {
  display: flex;
  gap: 16rpx;
}
.code-input { flex: 1; }
.code-btn {
  width: 200rpx; height: 96rpx;
  background: var(--brand-color-light);
  color: var(--brand-color);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
.code-btn.disabled {
  color: var(--text-tertiary);
  background: var(--bg-hover);
}
.code-btn:active:not(.disabled) { opacity: 0.8; }

/* ========== 隐私弹窗 ========== */
.privacy-popup {
  width: 640rpx;
  background: #FFF;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.privacy-header {
  padding: 40rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  border-bottom: 2rpx solid var(--border-color);
}
.privacy-scroll { height: 560rpx; padding: 32rpx; }
.privacy-section { margin-bottom: 32rpx; }
.privacy-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.privacy-section-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  text-align: justify;
}
.privacy-highlight {
  color: #1D5F8A;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
  padding: 16rpx;
  background: rgba(29,95,138,0.06);
  border-left: 6rpx solid #1D5F8A;
  border-radius: 0 8rpx 8rpx 0;
}
.privacy-footer {
  padding: 24rpx 32rpx 32rpx;
  border-top: 2rpx solid var(--border-color);
}

/* ========== 微信手机号授权按钮（原生 button） ========== */
.wechat-auth-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: #07C160;
  color: #FFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.20);
  line-height: 96rpx;
  padding: 0;
}
.wechat-auth-btn::after { border: none; }
.wechat-auth-btn:active { opacity: 0.85; }
.wechat-auth-btn.disabled {
  background: #A8D8B8;
  box-shadow: none;
}

/* ========== 头像选择弹窗 ========== */
.avatar-popup {
  background: #FFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 20rpx);
}
.avatar-popup-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 44rpx 32rpx;
  border-bottom: 2rpx solid var(--border-color);
}
.avatar-success-icon {
  margin-bottom: 16rpx;
}
.avatar-popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.avatar-popup-phone {
  font-size: 32rpx;
  color: #07C160;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.avatar-popup-body {
  padding: 36rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-popup-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 36rpx;
}
.avatar-preview-wrap {
  margin-bottom: 32rpx;
}
.avatar-preview-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid var(--brand-color);
  box-shadow: 0 8rpx 24rpx rgba(29, 95, 138, 0.15);
}
.avatar-preview-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  border: 4rpx dashed #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-choose-btn {
  width: 100%;
  height: 88rpx;
  background: var(--brand-color-light);
  color: var(--brand-color);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--brand-color);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 88rpx;
}
.avatar-choose-btn::after { border: none; }
.avatar-choose-btn:active { opacity: 0.8; }
.avatar-popup-footer {
  padding: 0 44rpx;
}
.avatar-confirm-btn {
  width: 100%;
  height: 96rpx;
  background: var(--brand-gradient);
  color: #FFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 96rpx;
  box-shadow: var(--shadow-brand);
}
.avatar-confirm-btn::after { border: none; }
.avatar-confirm-btn:active { opacity: 0.85; }
