.page {
  min-height: 100vh;
  background: #F5EDE5;
}

/* ══════════════════════════════════
   自定义导航栏
   ══════════════════════════════════ */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 28rpx 20rpx;
  background: #F5EDE5;
}
.nav-btn {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(92, 61, 46, 0.08);
}
.nav-btn:active { background: rgba(92, 61, 46, 0.15); }
.custom-nav .nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D2B1F;
  letter-spacing: 4rpx;
}

/* ══════════════════════════════════
   Tabs
   ══════════════════════════════════ */
.manage-tabs {
  --td-tab-item-color: #A09486;
  --td-tab-active-color: #5C3D2E;
  --td-tab-track-color: #C8963E;
}

/* ══════════════════════════════════
   Tab 内容
   ══════════════════════════════════ */
.tab-content {
  padding: 16rpx 28rpx 60rpx;
  min-height: 60vh;
}
.tab-action-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}
.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #C8963E, #A67930);
  padding: 14rpx 28rpx;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(200, 150, 62, 0.25);
}
.add-btn:active { opacity: 0.8; }
.add-btn-text {
  font-size: 26rpx;
  color: #FFF;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ══════════════════════════════════
   列表卡片
   ══════════════════════════════════ */
.card-list { display: flex; flex-direction: column; gap: 16rpx; }
.mgmt-card {
  background: #FFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(92, 61, 46, 0.04);
}
.mgmt-card:active { background: #FBF5EF; }
.card-row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2B1F;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.card-name.top-title { color: #C8963E; }
.card-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6rpx;
}
.card-label { font-size: 26rpx; color: #A09486; }
.card-value { font-size: 26rpx; color: #3D2B1F; font-weight: 500; }
.card-summary {
  font-size: 26rpx;
  color: #6B5E50;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.card-date {
  font-size: 22rpx;
  color: #A09486;
}
.card-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.top-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: #C8963E;
  background: #FBF5EB;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.type-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #E8F2FA;
  color: #1D5F8A;
}

/* 进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 8rpx 0;
}
.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #EDE4DB;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C8963E, #D4A854);
  border-radius: 6rpx;
  transition: width 0.3s;
}
.progress-text {
  font-size: 24rpx;
  color: #C8963E;
  font-weight: 700;
  flex-shrink: 0;
  width: 70rpx;
  text-align: right;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.status-tag.pending { background: #FBF5EB; color: #C8963E; }
.status-tag.approved { background: #ECF7F3; color: #2D8B6F; }
.status-tag.rejected { background: #FDECEE; color: #C94545; }
.status-tag.active { background: #E8F2FA; color: #1D5F8A; }

/* 空状态 */
.empty-tip { padding: 80rpx 0; }

/* ══════════════════════════════════
   弹窗通用
   ══════════════════════════════════ */
.popup-card {
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 32rpx);
  max-height: 70vh;
  overflow-y: auto;
}
.popup-tall { max-height: 85vh; }
.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 24rpx;
  border-bottom: 2rpx solid #EDE4DB;
  position: sticky;
  top: 0;
  background: #FFF;
  z-index: 2;
}
.popup-title { font-size: 36rpx; font-weight: 800; color: #3D2B1F; }
.popup-close {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #A09486;
  background: #F5EDE5;
  border-radius: 50%;
}
.popup-close:active { background: #EDE4DB; }
.popup-body { padding: 28rpx 0; }

/* ══════════════════════════════════
   详情展示
   ══════════════════════════════════ */
.detail-group {
  background: #FAF7F3;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}
.detail-row + .detail-row { border-top: 1rpx solid #EDE4DB; }
.detail-label { font-size: 26rpx; color: #A09486; }
.detail-value { font-size: 26rpx; color: #3D2B1F; font-weight: 500; }
.detail-content { margin-bottom: 24rpx; }
.content-text {
  display: block;
  font-size: 28rpx;
  color: #3D2B1F;
  line-height: 1.7;
  background: #FAF7F3;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 12rpx;
}

/* ══════════════════════════════════
   表单
   ══════════════════════════════════ */
.form-field { margin-bottom: 24rpx; }
.form-label {
  display: block;
  font-size: 26rpx;
  color: #5C3D2E;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.form-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #FAF7F3;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #3D2B1F;
}

/* ══════════════════════════════════
   操作按钮
   ══════════════════════════════════ */
.popup-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.popup-actions-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.btn-approve {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #2D8B6F, #1E6B52);
  display: flex; align-items: center; justify-content: center;
}
.btn-approve:active { opacity: 0.8; }
.btn-reject {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #C94545, #A33535);
  display: flex; align-items: center; justify-content: center;
}
.btn-reject:active { opacity: 0.8; }
.btn-action-text {
  font-size: 30rpx;
  color: #FFF;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.reject-text { color: #FFF; }

.btn-save {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #C8963E, #A67930);
  display: flex; align-items: center; justify-content: center;
}
.btn-save:active { opacity: 0.8; }
.btn-delete {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  background: #FDECEE;
  display: flex; align-items: center; justify-content: center;
}
.btn-delete:active { opacity: 0.8; }
.delete-text { color: #C94545; }

/* ══════════════════════════════════
   驳回信息
   ══════════════════════════════════ */
.reject-info {
  background: #FDECEE;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}
.reject-label {
  display: block;
  font-size: 24rpx;
  color: #C94545;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.reject-text {
  font-size: 26rpx;
  color: #C94545;
  line-height: 1.6;
}
.reject-form { margin-top: 24rpx; }
.reject-form-label {
  display: block;
  font-size: 26rpx;
  color: #5C3D2E;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.reject-confirm {
  background: linear-gradient(135deg, #C94545, #A33535);
  margin-top: 20rpx;
}

/* ══════════════════════════════════
   诉求状态按钮
   ══════════════════════════════════ */
.status-btns { margin-bottom: 24rpx; }
.status-btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}
.status-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  background: #FAF7F3;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx;
  color: #6B5E50;
  font-weight: 600;
  border: 2rpx solid #EDE4DB;
}
.status-btn.active {
  background: #FBF5EB;
  color: #C8963E;
  border-color: #C8963E;
}
.status-btn:active { opacity: 0.7; }
.reply-form { margin-top: 20rpx; }
.history-reply { margin-bottom: 24rpx; }
.reply-text {
  display: block;
  font-size: 26rpx;
  color: #2D8B6F;
  line-height: 1.6;
  background: #ECF7F3;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 12rpx;
}
