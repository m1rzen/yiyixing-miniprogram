.page { min-height: 100vh; background: #F5EDE5; }

.header-banner { padding: 100rpx 32rpx 48rpx; }
.nav-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 40rpx; }
.nav-btn { width: 68rpx; height: 68rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.15); border-radius: 50%; }
.nav-btn:active { background: rgba(255,255,255,0.3); }
.nav-title { font-size: 32rpx; font-weight: 700; color: #FFF; letter-spacing: 2rpx; }
.header-icon-wrap { width: 96rpx; height: 96rpx; background: rgba(255,255,255,0.2); border-radius: 28rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 24rpx; }
.header-desc { font-size: 28rpx; color: rgba(255,255,255,0.8); letter-spacing: 2rpx; }

.content { padding: 24rpx 28rpx 60rpx; }

/* Card */
.item-card { background: #FFF; border-radius: 20rpx; padding: 32rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(92,61,46,0.04); }
.item-card:active { opacity: 0.7; }

/* Row */
.item-row { display: flex; align-items: center; justify-content: space-between; }
.item-label { font-size: 30rpx; color: #3D2B1F; font-weight: 500; }
.item-value { font-size: 30rpx; color: #C8963E; font-weight: 700; }
.item-left { flex: 1; }
.item-title { font-size: 30rpx; color: #3D2B1F; font-weight: 600; display: block; margin-bottom: 8rpx; }
.item-meta { font-size: 24rpx; color: #A09486; }

/* Pill tag */
.pill { padding: 6rpx 20rpx; border-radius: 100rpx; flex-shrink: 0; }
.pill text { font-size: 22rpx; color: #FFF; font-weight: 600; }
.pill-gold { background: #C8963E; }
.pill-green { background: #2D8B6F; }

/* Progress */
.item-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.progress-track { height: 12rpx; background: #EDE4DB; border-radius: 6rpx; overflow: hidden; margin-bottom: 8rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #C8963E, #D4A854); border-radius: 6rpx; transition: width .6s; }
.progress-label { font-size: 24rpx; color: #A09486; }

/* Form */
.form-card { background: #FFF; border-radius: 20rpx; padding: 36rpx; box-shadow: 0 2rpx 12rpx rgba(92,61,46,0.04); }
.form-group { margin-bottom: 32rpx; }
.form-label { display: block; font-size: 28rpx; color: #3D2B1F; font-weight: 600; margin-bottom: 16rpx; }
.form-picker { height: 88rpx; background: #F5EDE5; border-radius: 16rpx; padding: 0 24rpx; display: flex; align-items: center; justify-content: space-between; font-size: 30rpx; color: #3D2B1F; }
.form-textarea { width: 100%; min-height: 200rpx; background: #F5EDE5; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; color: #3D2B1F; box-sizing: border-box; }
.form-input { height: 88rpx; background: #F5EDE5; border-radius: 16rpx; padding: 0 24rpx; font-size: 28rpx; color: #3D2B1F; box-sizing: border-box; }
.submit-btn { margin-top: 16rpx; background: linear-gradient(135deg, #C8963E, #A67930); height: 92rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; }
.submit-btn:active { opacity: 0.8; }
.submit-btn-text { font-size: 32rpx; color: #FFF; font-weight: 700; letter-spacing: 4rpx; }

/* Empty */
.empty-hint { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 80rpx 0; font-size: 28rpx; color: #A09486; }
