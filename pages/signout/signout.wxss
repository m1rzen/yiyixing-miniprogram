.signout-page {
  min-height: 100vh;
  position: relative;
  background: var(--bg-primary);
}
.bg-top {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 360rpx;
  background: linear-gradient(170deg, #0C2E45 0%, #1D5F8A 45%, #134566 100%);
  z-index: 1;
}
.content {
  position: relative; z-index: 3;
  padding: 0 28rpx;
  min-height: 100vh;
}

/* 签退卡片 */
.signout-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  padding: 44rpx 36rpx;
  margin-bottom: 24rpx;
}
.sc-icon-area {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}
.sc-ring {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: rgba(201,69,69,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
.sc-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  display: block;
  margin-bottom: 12rpx;
}
.sc-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
  display: block;
  margin-bottom: 36rpx;
  line-height: 1.6;
}
.sc-info {
  padding: 24rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  margin-bottom: 36rpx;
}
.sci-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.sci-row:last-child { margin-bottom: 0; }
.sci-label { font-size: 28rpx; color: var(--text-tertiary); }
.sci-value { font-size: 28rpx; color: var(--text-primary); font-weight: 500; }

/* 已签退卡片 */
.done-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  padding: 52rpx 36rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.dc-icon {
  margin-bottom: 24rpx;
  animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.dc-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--success-color);
  margin-bottom: 12rpx;
}
.dc-time {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}
.dc-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 36rpx;
}
.dc-info {
  width: 100%;
  padding: 24rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  margin-bottom: 36rpx;
}

/* 提示 */
.tips-card {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  padding: 24rpx 28rpx;
  background: #FFF;
  border-radius: var(--radius-lg);
}
.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
  flex: 1;
}

@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
