<view class="profile-page">
  <view class="bg-top"></view>

  <view class="content immersive-content">
    <view class="custom-nav">
      <view class="nav-back" bindtap="goBack">
        <t-icon name="chevron-left" size="44rpx" color="#FFF" />
      </view>
      <text class="nav-title">个人中心</text>
    </view>

    <!-- 用户头像卡片 -->
    <view class="profile-header-card">
      <view class="ph-avatar">
        <t-icon name="user" size="64rpx" color="#FFF" />
      </view>
      <view class="ph-name">
        {{userInfo.name || '微信用户'}}
        <view class="status-tag approved" wx:if="{{userInfo.name}}">已实名</view>
        <view class="status-tag pending" wx:else>未实名</view>
      </view>
      <view class="ph-phone">{{userInfo.phone || '未绑定手机'}}</view>
    </view>

    <!-- 通行凭证入口 -->
    <view class="menu-card">
      <view class="menu-item" bindtap="goToStatus" hover-class="menu-hover">
        <view class="mi-left">
          <view class="mi-icon" style="background: rgba(45,139,111,0.1);">
            <t-icon name="qrcode" size="36rpx" color="#2D8B6F" />
          </view>
          <text class="mi-text">我的通行凭证</text>
        </view>
        <view class="mi-right">
          <view class="status-tag active" wx:if="{{hasActiveVisit}}">有效</view>
          <t-icon name="chevron-right" size="36rpx" color="#D1D5DB" />
        </view>
      </view>
    </view>

    <!-- 历史通行记录 -->
    <view class="history-section" wx:if="{{visitHistory.length > 0}}">
      <view class="history-header">
        <text class="history-title">历史通行记录</text>
        <text class="history-count">{{visitHistory.length}} 条</text>
      </view>
      <view class="history-list">
        <view class="history-item" wx:for="{{visitHistory}}" wx:key="_id">
          <view class="hi-left">
            <view class="hi-status-dot {{item.status}}"></view>
          </view>
          <view class="hi-content">
            <view class="hi-top-row">
              <text class="hi-community">{{item.community}}</text>
              <view class="status-tag {{item.status === 'approved' ? 'approved' : item.status === 'rejected' ? 'rejected' : item.status === 'completed' ? 'approved' : 'pending'}}">
                {{item.status === 'approved' ? '通行中' : item.status === 'rejected' ? '已驳回' : item.status === 'completed' ? '已签退' : '审核中'}}
              </view>
            </view>
            <text class="hi-reason">{{item.reason}}</text>
            <text class="hi-time">{{item.createTimeStr || '-'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 无历史记录 -->
    <view class="menu-card" wx:if="{{visitHistory.length === 0}}">
      <view class="menu-item" hover-class="menu-hover">
        <view class="mi-left">
          <view class="mi-icon" style="background: rgba(29,95,138,0.1);">
            <t-icon name="time" size="36rpx" color="#1D5F8A" />
          </view>
          <text class="mi-text">历史通行记录</text>
        </view>
        <view class="mi-right">
          <text class="mi-count">暂无记录</text>
          <t-icon name="chevron-right" size="36rpx" color="#D1D5DB" />
        </view>
      </view>
    </view>

    <!-- 操作区 -->
    <view class="action-card">
      <view class="menu-item" bindtap="handleClearData" hover-class="menu-hover">
        <view class="mi-left">
          <view class="mi-icon" style="background: rgba(201,69,69,0.1);">
            <t-icon name="delete" size="36rpx" color="#C94545" />
          </view>
          <text class="mi-text">清除本地数据</text>
        </view>
        <t-icon name="chevron-right" size="36rpx" color="#D1D5DB" />
      </view>
    </view>

    <!-- 退出按钮 -->
    <view class="bottom-area safe-bottom">
      <view class="logout-btn" bindtap="handleLogout" hover-class="logout-hover">
        <t-icon name="poweroff" size="32rpx" color="#C94545" />
        <text class="logout-text">退出当前账号</text>
      </view>

      <view class="app-info">
        <text>邑易行 v2.0.0</text>
        <text>五邑侨乡 · 江门蓬江区智慧社区</text>
      </view>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
