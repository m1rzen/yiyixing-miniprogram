.profile-page {
  min-height: 100vh;
  position: relative;
  background: var(--bg-primary);
}

.bg-top {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 480rpx;
  background: linear-gradient(170deg, #0C2E45 0%, #1D5F8A 45%, #134566 100%);
  z-index: 1;
}

.content {
  position: relative; z-index: 3;
  padding: 0 28rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 头像卡片 */
.profile-header-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 36rpx;
  margin-bottom: 24rpx;
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(15px);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(255,255,255,0.12);
}
.ph-avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  border: 3rpx solid rgba(200,150,62,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}
.ph-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFF;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.ph-phone {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

/* 菜单卡片 */
.menu-card {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
  overflow: hidden;
}
.action-card {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--border-color);
}
.menu-item:last-child { border-bottom: none; }
.menu-hover { background: var(--bg-hover); }
.mi-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.mi-icon {
  width: 72rpx; height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}
.mi-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}
.mi-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.mi-count {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 历史记录 */
.history-section {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
  overflow: hidden;
}
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}
.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.history-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.history-list { padding: 16rpx 32rpx 24rpx; }
.history-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}
.history-item:last-child { border-bottom: none; padding-bottom: 0; }
.hi-left {
  padding-top: 8rpx;
  flex-shrink: 0;
}
.hi-status-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--text-tertiary);
}
.hi-status-dot.approved { background: var(--success-color); }
.hi-status-dot.pending { background: var(--warning-color); }
.hi-status-dot.rejected { background: var(--danger-color); }
.hi-status-dot.completed { background: var(--text-tertiary); }
.hi-content { flex: 1; min-width: 0; }
.hi-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}
.hi-community {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}
.hi-reason {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4rpx;
}
.hi-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
}

/* 退出 */
.bottom-area {
  margin-top: auto;
  padding: 24rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}
.logout-btn {
  width: 100%; height: 96rpx;
  border-radius: var(--radius-lg);
  background: #FFF;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.logout-hover { background: var(--bg-hover); }
.logout-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--danger-color);
}

.app-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding-bottom: 20rpx;
}
