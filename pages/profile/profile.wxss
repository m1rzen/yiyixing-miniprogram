.profile-page { min-height: 100vh; position: relative; background-color: #F0F2F5; display: flex; flex-direction: column; }
.chikan-bg-full { position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 1; }
.bg-overlay-full { position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 2; background: linear-gradient(180deg, rgba(38, 85, 109, 0.95) 0%, rgba(240, 242, 245, 0.2) 40%, rgba(240, 242, 245, 0.9) 100%); }
.content-wrap { position: relative; z-index: 3; padding: 0 40rpx; display: flex; flex-direction: column; flex: 1; min-height: 100vh; }

.nav-bar { display: flex; align-items: center; padding-top: 100rpx; margin-bottom: 40rpx; }
.back-btn { width: 80rpx; height: 80rpx; display: flex; align-items: center; justify-content: flex-start; }
.nav-title { font-size: 36rpx; font-weight: 600; color: #FFF; margin-left: -20rpx; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1); }

/* 头部名片 */
.profile-glass-card { border-radius: 40rpx; padding: 60rpx 40rpx; margin-bottom: 40rpx; background: rgba(255, 255, 255, 0.25); backdrop-filter: blur(25px); border: 2rpx solid rgba(255, 255, 255, 0.4); box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.05); display: flex; flex-direction: column; align-items: center; }
.avatar-wrap-large { width: 140rpx; height: 140rpx; background: rgba(255, 255, 255, 0.3); border-radius: 50%; display: flex; justify-content: center; align-items: center; margin-bottom: 24rpx; border: 4rpx solid rgba(255, 255, 255, 0.6); box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }
.user-name-large { font-size: 40rpx; font-weight: 600; color: #FFF; margin-bottom: 12rpx; display: flex; align-items: center; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.15); }
.role-tag-warm { font-size: 22rpx; background: #00A870; color: #FFF; padding: 4rpx 16rpx; border-radius: 10rpx; margin-left: 16rpx; font-weight: 400; text-shadow: none; box-shadow: 0 4rpx 8rpx rgba(0,168,112,0.3); }
.user-phone-large { font-size: 30rpx; color: rgba(255, 255, 255, 0.9); }

/* 菜单列表 */
.menu-glass-card { border-radius: 30rpx; padding: 10rpx 30rpx; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(25px); border: 2rpx solid #FFF; box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08); margin-bottom: 60rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 36rpx 10rpx; border-bottom: 2rpx solid rgba(0,0,0,0.04); transition: background 0.2s; }
.menu-item:last-child { border-bottom: none; }
.item-hover { background: rgba(0,0,0,0.02); border-radius: 16rpx; }
.menu-left { display: flex; align-items: center; gap: 20rpx; }
.menu-text { font-size: 32rpx; color: #333; font-weight: 500; }
.menu-right { display: flex; align-items: center; gap: 16rpx; }
.status-badge { font-size: 24rpx; color: #00A870; background: rgba(0,168,112,0.1); padding: 4rpx 16rpx; border-radius: 100rpx; }

/* 退出按钮 */
.bottom-action { margin-top: auto; padding-bottom: calc(env(safe-area-inset-bottom) + 60rpx); }
.logout-btn-glass { width: 100%; height: 96rpx; border-radius: 24rpx; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px); border: 2rpx solid #FFF; box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05); display: flex; justify-content: center; align-items: center; gap: 12rpx; transition: all 0.2s; }
.logout-text { font-size: 32rpx; font-weight: 600; color: #E34D59; }
.btn-hover { background: rgba(255, 255, 255, 1); transform: scale(0.98); }