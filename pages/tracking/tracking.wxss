.tracking-page {
  min-height: 100vh;
  position: relative;
  background: var(--bg-primary);
}
.bg-top {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 360rpx;
  background: linear-gradient(170deg, #0C2E45 0%, #1D5F8A 45%, #134566 100%);
  z-index: 1;
}
.content {
  position: relative; z-index: 3;
  padding: 0 28rpx;
  min-height: 100vh;
}

/* 追踪卡片 */
.tracking-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  margin-bottom: 24rpx;
}
.tc-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 36rpx 28rpx;
}
.tc-status.active { background: linear-gradient(180deg, var(--qiao-jade-light) 0%, #FFF 100%); }
.tc-status.inactive { background: linear-gradient(180deg, #F5F5F5 0%, #FFF 100%); }
.tc-ring {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.tc-status.active .tc-ring { background: rgba(45,139,111,0.1); }
.tc-status.inactive .tc-ring { background: rgba(156,163,175,0.1); }
.tc-ring.pulse { animation: pulse 2s ease-in-out infinite; }
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(45,139,111,0.2); }
  50% { box-shadow: 0 0 0 20rpx rgba(45,139,111,0.05); }
}
.tc-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.tc-time {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--success-color);
  font-variant-numeric: tabular-nums;
  letter-spacing: 4rpx;
}

/* 统计 */
.tc-stats {
  display: flex;
  align-items: center;
  padding: 24rpx 36rpx;
  border-top: 2rpx solid var(--border-color);
  border-bottom: 2rpx solid var(--border-color);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.stat-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.stat-divider {
  width: 2rpx; height: 60rpx;
  background: var(--border-color);
}

/* 操作 */
.tc-actions { padding: 28rpx 36rpx; }
.action-row { display: flex; gap: 16rpx; }
.manual-btn {
  flex: 1;
  height: 88rpx !important;
  border-radius: var(--radius-lg) !important;
}
.signout-btn {
  flex: 1;
  height: 88rpx !important;
  border-radius: var(--radius-lg) !important;
}

/* 打卡记录 */
.logs-section {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.logs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.logs-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.logs-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.logs-list { padding-left: 20rpx; }
.log-item {
  display: flex;
  position: relative;
  padding-bottom: 24rpx;
}
.log-item:last-child { padding-bottom: 0; }
.log-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: var(--border-color);
  margin-top: 8rpx;
  position: relative;
  z-index: 2;
}
.log-dot.latest {
  background: var(--success-color);
  box-shadow: 0 0 0 6rpx rgba(45,139,111,0.12);
}
.log-line {
  position: absolute;
  left: 7rpx; top: 24rpx; bottom: 0;
  width: 2rpx;
  background: var(--border-color);
  z-index: 1;
}
.log-content { margin-left: 20rpx; flex: 1; }
.log-time {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  display: block;
}
.log-coord {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-family: monospace;
  display: block;
  margin-top: 4rpx;
}
.log-tag {
  display: inline-block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--success-color);
  background: var(--success-light);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

/* 提示 */
.tips-card {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  padding: 24rpx 28rpx;
  background: #FFF;
  border-radius: var(--radius-lg);
  margin-bottom: 40rpx;
}
.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
  flex: 1;
}
