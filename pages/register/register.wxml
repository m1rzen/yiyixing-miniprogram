<view class="register-page">
  <image class="chikan-bg-full" src="https://media.nfnews.com/nfplus/ossfs/pic/xy/202504/22/d07bf98e95d64e6caa519631be06909c_batchwm.jpg" mode="aspectFill"></image>
  <view class="bg-overlay-full"></view>

  <view class="content-wrap">
    <view class="nav-bar">
      <view class="back-btn" bindtap="goBack">
        <t-icon name="chevron-left" size="48rpx" color="#FFF"></t-icon>
      </view>
      <text class="nav-title">访客登记</text>
    </view>

    <view class="form-glass-card">
      <view class="form-header">
        <t-icon name="edit-2" size="40rpx" color="#3F8DB4"></t-icon>
        <text class="form-title">填写实名信息</text>
      </view>

      <view class="form-item">
        <text class="item-label"><text class="required">*</text>真实姓名</text>
        <view class="item-value-box">
          <input class="value-text input-field" placeholder="请输入姓名" placeholder-class="placeholder" value="{{name}}" bindinput="onNameChange" />
        </view>
      </view>

      <view class="form-item">
        <text class="item-label"><text class="required">*</text>手机号码</text>
        <view class="item-value-box">
          <input class="value-text input-field" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="placeholder" value="{{phone}}" bindinput="onPhoneChange" />
        </view>
      </view>

      <view class="form-item">
        <text class="item-label"><text class="required">*</text>身份证号</text>
        <view class="item-value-box">
          <input class="value-text input-field" type="idcard" maxlength="18" placeholder="请输入身份证号" placeholder-class="placeholder" value="{{idCard}}" bindinput="onIdCardChange" />
        </view>
      </view>

      <view class="form-item">
        <text class="item-label"><text class="required">*</text>登记地点</text>
        <view class="item-value-box read-only">
          <text class="value-text">{{currentCommunity}}</text>
          <text class="action-text" bindtap="changeCommunity">修改</text>
        </view>
      </view>

      <view class="form-item">
        <text class="item-label"><text class="required">*</text>登记事由</text>
        <view class="item-value-box clickable" bindtap="openReasonPopup">
          <text class="value-text {{reason ? '' : 'placeholder'}}">{{reason ? reason : '请选择拜访事由'}}</text>
          <text class="action-text">选择</text>
        </view>
      </view>
    </view>

    <t-button block t-class="global-primary-btn submit-glass-btn" bindtap="handleSubmit">
      提交登记
    </t-button>
  </view>

  <t-popup visible="{{reasonVisible}}" bind:visible-change="onReasonVisibleChange" placement="bottom" close-btn>
    <view class="popup-container">
      <view class="popup-title">请选择登记事由</view>
      <view class="reason-grid">
        <view class="reason-item" wx:for="{{reasonOptions}}" wx:key="name" bindtap="selectReason" data-name="{{item.name}}">
          <t-icon name="{{item.icon}}" size="56rpx" color="{{item.color}}"></t-icon>
          <text class="reason-name">{{item.name}}</text>
        </view>
      </view>
    </view>
  </t-popup>

  <t-toast id="t-toast"></t-toast>
</view>