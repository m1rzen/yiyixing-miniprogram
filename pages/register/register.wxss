.register-page { min-height: 100vh; position: relative; background-color: #F0F2F5; }

/* 沉浸式背景层复用 */
.chikan-bg-full { position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 1; }
.bg-overlay-full { position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 2; background: linear-gradient(180deg, rgba(38, 85, 109, 0.95) 0%, rgba(240, 242, 245, 0.2) 40%, rgba(240, 242, 245, 0.9) 100%); }

.content-wrap { position: relative; z-index: 3; padding: 0 40rpx; display: flex; flex-direction: column; min-height: 100vh; }

/* 自定义导航栏 */
.nav-bar { display: flex; align-items: center; padding-top: 100rpx; margin-bottom: 40rpx; }
.back-btn { width: 80rpx; height: 80rpx; display: flex; align-items: center; justify-content: flex-start; }
.nav-title { font-size: 36rpx; font-weight: 600; color: #FFF; margin-left: -20rpx; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1); }

/* 亚克力表单卡片 */
.form-glass-card { 
  border-radius: 40rpx; padding: 40rpx; margin-bottom: 60rpx; 
  background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(25px); border: 2rpx solid #FFFFFF; box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.08); 
}

.form-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 50rpx; padding-bottom: 30rpx; border-bottom: 2rpx dashed rgba(0,0,0,0.06); }
.form-title { font-size: 34rpx; font-weight: 600; color: #1A1A1A; }

.form-item { margin-bottom: 48rpx; }
.form-item:last-child { margin-bottom: 10rpx; }
.item-label { display: block; font-size: 28rpx; color: #555; margin-bottom: 20rpx; font-weight: 500; }
.required { color: #E34D59; margin-right: 8rpx; }

/* 表单输入框/选择框统一外观 */
.item-value-box { 
  display: flex; justify-content: space-between; align-items: center; 
  height: 96rpx; padding: 0 32rpx; background: rgba(245, 247, 250, 0.6); border-radius: 20rpx; border: 2rpx solid rgba(0,0,0,0.03);
}
.read-only { background: rgba(0,0,0,0.02); }
.clickable:active { background: rgba(0,0,0,0.05); }

.value-text { font-size: 32rpx; color: #1A1A1A; font-weight: 500; }
.placeholder { color: #BBB; font-weight: 400; }
.action-text { font-size: 28rpx; color: #3F8DB4; font-weight: 500; }

/* 🌟 新增：外卖照片上传框样式 */
.upload-box {
  height: 200rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  border: 2rpx dashed rgba(63, 141, 180, 0.4); /* 孔雀蓝虚线边框 */
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  transition: all 0.2s;
  overflow: hidden;
}
.upload-box:active { background: rgba(255, 255, 255, 0.9); }
.upload-text { font-size: 26rpx; color: #3F8DB4; font-weight: 500; }
.uploaded-img { width: 100%; height: 100%; border-radius: 20rpx; }

/* 提交按钮 */
.submit-glass-btn { 
  background: linear-gradient(135deg, #3F8DB4 0%, #2A6685 100%) !important; 
  color: #FFF !important; border-radius: 24rpx !important; height: 100rpx !important; box-shadow: 0 16rpx 40rpx rgba(63, 141, 180, 0.3) !important; border: none !important;
}

/* ================= 弹窗样式 ================= */

/* 1. 事由选择弹窗 */
.t-popup { border-radius: 40rpx 40rpx 0 0 !important; }
.popup-container { padding: 50rpx 40rpx calc(env(safe-area-inset-bottom) + 30rpx); background: #FFF; }
.popup-title { font-size: 36rpx; font-weight: 600; color: #1A1A1A; text-align: center; margin-bottom: 50rpx; }

/* 🌟 核心修改：使用 CSS Grid 强制 4列横向排版 */
.reason-grid { 
  display: grid; 
  grid-template-columns: repeat(4, 1fr); /* 严格划分 4 等分 */
  row-gap: 30rpx; 
  column-gap: 20rpx; 
}
.reason-item { 
  width: 100%; 
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 24rpx 0; background: #F8FAFC; border-radius: 24rpx; transition: all 0.2s; border: 2rpx solid transparent;
}
.reason-item:active { background: rgba(63, 141, 180, 0.05); border-color: rgba(63, 141, 180, 0.2); transform: scale(0.95); }
.reason-name { font-size: 24rpx; color: #444; margin-top: 16rpx; font-weight: 500; }

/* 2. 智能拦截弹窗 */
.platform-auth-container { background: #FFF; overflow: hidden; padding-bottom: calc(env(safe-area-inset-bottom) + 30rpx); }
.platform-header { padding: 40rpx; display: flex; align-items: center; justify-content: center; position: relative; }

.theme-meituan { background: linear-gradient(135deg, #FFC107 0%, #FF9800 100%); }
.theme-shunfeng { background: linear-gradient(135deg, #EF5350 0%, #D32F2F 100%); }
.theme-jingdong { background: linear-gradient(135deg, #E53935 0%, #B71C1C 100%); }
.theme-meituan-text { color: #FF9800; }
.theme-shunfeng-text { color: #D32F2F; }
.theme-jingdong-text { color: #E53935; }
.theme-meituan-bg { background: #FF9800; color: #FFF; }
.theme-shunfeng-bg { background: #D32F2F; color: #FFF; }
.theme-jingdong-bg { background: #E53935; color: #FFF; }

.brand-bar { display: flex; align-items: center; gap: 16rpx; }
.brand-title { font-size: 36rpx; font-weight: 600; color: #FFF; letter-spacing: 2rpx;}

.platform-content { padding: 50rpx 40rpx; }
.auth-desc { font-size: 30rpx; color: #444; line-height: 1.6; display: block; margin-bottom: 60rpx; text-align: justify; }
.highlight { font-weight: bold; padding: 0 4rpx; }

.auth-actions { display: flex; gap: 24rpx; }
.btn-cancel, .btn-confirm { flex: 1; height: 96rpx; display: flex; justify-content: center; align-items: center; border-radius: 20rpx; font-size: 32rpx; font-weight: 600; }
.btn-cancel { background: #F0F2F5; color: #666; }
.btn-confirm:active { opacity: 0.9; transform: scale(0.98); }

/* ================= 🌟 追加：表单输入框适配补丁 ================= */
.input-field {
  flex: 1;
  height: 100%;
  width: 100%;
  background: transparent;
  border: none;
  outline: none;
  min-height: 96rpx; /* 与容器高度保持一致 */
}