.register-page {
  min-height: 100vh;
  position: relative;
  background: var(--bg-primary);
}

.bg-top {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 360rpx;
  background: linear-gradient(170deg, #0C2E45 0%, #1D5F8A 45%, #134566 100%);
  z-index: 1;
}

.content {
  position: relative; z-index: 3;
  padding: 0 28rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 平台标识 */
.platform-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  align-self: flex-start;
  padding: 10rpx 28rpx;
  background: rgba(200,150,62,0.2);
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #FFF;
  font-weight: 500;
  margin-bottom: 20rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(200,150,62,0.2);
}

/* 表单卡片 */
.form-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
  margin-bottom: 32rpx;
}
.form-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 24rpx;
  margin-bottom: 28rpx;
  border-bottom: 2rpx solid var(--border-color);
}
.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.form-item { margin-bottom: 28rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-bottom: 14rpx;
}
.required {
  color: var(--danger-color);
  margin-right: 6rpx;
}
.optional {
  color: var(--text-tertiary);
  font-weight: 400;
  font-size: 24rpx;
}

.form-input-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  padding: 0 28rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.form-input-wrap:focus-within {
  border-color: var(--brand-color);
  background: #FFF;
  box-shadow: 0 0 0 4rpx rgba(29,95,138,0.08);
}
.form-input-wrap.clickable:active { background: var(--bg-hover); }
.form-input {
  flex: 1; height: 100%;
  background: transparent;
  border: none;
  font-size: 30rpx;
  color: var(--text-primary);
}
.form-value {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}
.form-value.placeholder {
  color: var(--text-tertiary);
  font-weight: 400;
}

/* 照片上传 */
.photo-area { display: flex; gap: 16rpx; }
.photo-upload {
  width: 200rpx; height: 200rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-primary);
  border: 2rpx dashed var(--border-color);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.photo-upload:active {
  background: var(--bg-hover);
  border-color: var(--brand-color);
}
.photo-tip {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.photo-preview {
  width: 200rpx; height: 200rpx;
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.preview-img { width: 100%; height: 100%; }
.photo-remove {
  position: absolute; top: 8rpx; right: 8rpx;
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 提交区域 */
.submit-area {
  margin-top: auto;
  padding: 32rpx 0;
}

/* 事由弹窗 */
.reason-popup {
  padding: 44rpx 36rpx calc(env(safe-area-inset-bottom) + 30rpx);
  background: #FFF;
}
.reason-popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 36rpx;
}
.reason-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}
.reason-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-lg);
  background: var(--bg-primary);
  transition: all 0.2s;
}
.reason-item:active {
  transform: scale(0.95);
  background: var(--bg-hover);
}
.reason-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.reason-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
