<view class="page">
  <!-- 背景 -->
  <view class="bg"></view>
  <view class="orb orb-a"></view>
  <view class="orb orb-b"></view>

  <!-- 头部 -->
  <view class="top {{animReady ? 'show' : ''}}">
    <view class="brand-row">
      <view class="brand-dot"></view>
      <text class="brand-name">邑 Yi</text>
    </view>
    <text class="greeting">你好，欢迎回来</text>
    <text class="title">选择服务</text>
  </view>

  <!-- 双卡片 — 左右并排 -->
  <view class="cards {{animReady ? 'show delay' : ''}}">

    <view class="card" hover-class="card-tap" bindtap="goToYiyixing">
      <!-- 图标 -->
      <view class="card-icon icon-blue">
        <t-icon name="secured" size="52rpx" color="#FFF" />
      </view>
      <!-- 名称 -->
      <text class="card-name">邑易行</text>
      <text class="card-desc">访客通行登记</text>
      <!-- 箭头 -->
      <view class="card-arrow arrow-blue">
        <t-icon name="arrow-right" size="28rpx" color="#FFF" />
      </view>
    </view>

    <view class="card" hover-class="card-tap" bindtap="goToYixiaoqu">
      <view class="card-icon icon-gold">
        <t-icon name="city-1" size="52rpx" color="#FFF" />
      </view>
      <text class="card-name">邑小区</text>
      <text class="card-desc">智慧社区生活</text>
      <view class="card-arrow arrow-gold">
        <t-icon name="arrow-right" size="28rpx" color="#FFF" />
      </view>
    </view>

  </view>

  <!-- 底部标语 -->
  <view class="bottom {{animReady ? 'show delay2' : ''}}">
    <view class="bottom-line"></view>
    <text class="bottom-text">五邑侨乡 · 智慧社区公共服务平台</text>
  </view>
</view>
