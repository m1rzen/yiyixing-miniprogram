<view class="page">
  <!-- 暖色背景 -->
  <view class="bg"></view>

  <!-- ====== 上半：品牌主视觉区 ====== -->
  <view class="hero {{animReady ? 'show' : ''}}">
    <!-- 左上英文标题 -->
    <text class="hero-en">SMART COMMUNITY</text>
    <view class="hero-label">
      <text class="hero-label-text">智慧社区</text>
    </view>

    <!-- 大标题 -->
    <text class="hero-title">五邑侨乡生态</text>

    <!-- 碉楼天际线插画 — SVG -->
    <view class="hero-visual">
      <image class="skyline-img" src="./skyline.svg" mode="widthFix" />
    </view>

    <!-- 右侧小装饰 -->
    <view class="hero-side">
      <view class="color-strip"></view>
      <text class="side-zh">蓬江区</text>
      <text class="side-en">Pengjiang</text>
    </view>
  </view>

  <!-- ====== 下半：双选择区 ====== -->
  <view class="choices {{animReady ? 'show delay' : ''}}">
    <!-- 邑易行 -->
    <view class="choice" hover-class="choice-tap" bindtap="goToYiyixing">
      <text class="choice-zh">邑易行</text>
      <text class="choice-en">PASS</text>
    </view>

    <!-- 分割线 -->
    <view class="choice-divider"></view>

    <!-- 邑小区 -->
    <view class="choice" hover-class="choice-tap" bindtap="goToYixiaoqu">
      <text class="choice-zh">邑小区</text>
      <text class="choice-en">COMMUNITY</text>
    </view>
  </view>

  <!-- ====== 底部入口行 ====== -->
  <view class="bottom-row {{animReady ? 'show delay2' : ''}}">
    <view class="bottom-item" bindtap="goToYiyixing">
      <view class="bottom-dot dot-blue"></view>
      <text class="bottom-label">访客通行</text>
    </view>
    <view class="bottom-item" bindtap="goToYixiaoqu">
      <view class="bottom-dot dot-gold"></view>
      <text class="bottom-label">社区生活</text>
    </view>
    <view class="bottom-item">
      <view class="bottom-dot dot-green"></view>
      <text class="bottom-label">保安端</text>
    </view>
    <view class="bottom-item" bindtap="showAdminLogin">
      <view class="bottom-dot dot-brown"></view>
      <text class="bottom-label">管理员入口</text>
    </view>
    <view class="bottom-item">
      <view class="bottom-dot dot-red"></view>
      <text class="bottom-label">关于我们</text>
    </view>
  </view>

  <!-- 底部标语 -->
  <view class="slogan {{animReady ? 'show delay2' : ''}}">
    <text class="slogan-text">Having safe community\nand happy living equally.</text>
  </view>

  <!-- ====== 弹窗：管理员登录 ====== -->
  <t-popup visible="{{adminLoginPopupVisible}}" placement="bottom" bind:close="hideAdminLogin">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">管理员登录</text>
        <text class="popup-close" bindtap="hideAdminLogin">✕</text>
      </view>
      <view class="popup-body">
        <text class="popup-desc">登录管理后台以管理社区事务</text>
        <view class="admin-form">
          <view class="admin-field">
            <text class="admin-label">选择小区</text>
            <picker mode="selector" range="{{communityNames}}" value="{{selectedCommunityIdx}}" bindchange="onCommunityChange">
              <view class="picker-box">
                <text class="picker-text">{{communityNames[selectedCommunityIdx] || '请选择小区'}}</text>
                <t-icon name="chevron-right" size="28rpx" color="#A09486" />
              </view>
            </picker>
          </view>
          <view class="admin-field">
            <text class="admin-label">手机号</text>
            <input class="admin-input" type="number" placeholder="请输入手机号" bindinput="onAdminPhoneInput" maxlength="11" />
          </view>
          <view class="admin-field">
            <text class="admin-label">密码</text>
            <input class="admin-input" password placeholder="请输入密码" bindinput="onAdminPasswordInput" maxlength="32" />
          </view>
        </view>
        <view class="admin-submit-btn" bindtap="doAdminLogin">
          <text class="admin-submit-text">登录</text>
        </view>
      </view>
    </view>
  </t-popup>

  <t-toast id="t-toast" />
</view>
