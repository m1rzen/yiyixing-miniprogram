<view class="page">
  <!-- 暖色背景 -->
  <view class="bg"></view>

  <!-- ====== 上半：品牌主视觉区 ====== -->
  <view class="hero {{animReady ? 'show' : ''}}">
    <!-- 左上英文标题 -->
    <text class="hero-en">SMART COMMUNITY</text>
    <view class="hero-label">
      <text class="hero-label-text">智慧社区</text>
    </view>

    <!-- 大标题 -->
    <text class="hero-title">五邑侨乡生态</text>

    <!-- 碉楼天际线插画 — SVG -->
    <view class="hero-visual">
      <image class="skyline-img" src="./skyline.svg" mode="widthFix" />
    </view>

    <!-- 右侧小装饰 -->
    <view class="hero-side">
      <view class="color-strip"></view>
      <text class="side-zh">蓬江区</text>
      <text class="side-en">Pengjiang</text>
    </view>
  </view>

  <!-- ====== 下半：双选择区 ====== -->
  <view class="choices {{animReady ? 'show delay' : ''}}">
    <!-- 邑易行 -->
    <view class="choice" hover-class="choice-tap" bindtap="goToYiyixing">
      <text class="choice-zh">邑易行</text>
      <text class="choice-en">PASS</text>
    </view>

    <!-- 分割线 -->
    <view class="choice-divider"></view>

    <!-- 邑小区 -->
    <view class="choice" hover-class="choice-tap" bindtap="goToYixiaoqu">
      <text class="choice-zh">邑小区</text>
      <text class="choice-en">COMMUNITY</text>
    </view>
  </view>

  <!-- ====== 底部快捷入口 ====== -->
  <view class="bottom-row {{animReady ? 'show delay2' : ''}}">
    <view class="bottom-item" bindtap="showAbout">
      <text class="bottom-label">关于我们</text>
    </view>
    <view class="bottom-dot"></view>
    <view class="bottom-item" bindtap="showVersion">
      <text class="bottom-label">版本信息</text>
    </view>
  </view>

  <!-- 底部标语 -->
  <view class="slogan {{animReady ? 'show delay2' : ''}}">
    <text class="slogan-text">Having safe community\nand happy living equally.</text>
  </view>

  <!-- ====== 弹窗：关于我们 ====== -->
  <t-popup visible="{{aboutPopupVisible}}" placement="bottom" bind:close="hideAbout">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">关于我们</text>
        <text class="popup-close" bindtap="hideAbout">✕</text>
      </view>
      <view class="popup-body about-body">
        <view class="about-logo">
          <view class="about-logo-dot"></view>
          <text class="about-logo-text">邑 Yi</text>
        </view>
        <text class="about-appname">邑易行 · 五邑侨乡智慧社区</text>
        <view class="about-divider"></view>
        <text class="about-desc">邑易行是面向五邑侨乡地区的智慧社区综合服务平台，由「邑易行」访客通行系统和「邑小区」智慧社区平台两大模块组成，致力于为社区居民提供安全、便捷、温暖的生活服务。</text>
        <view class="about-section">
          <text class="about-section-title">邑易行 · 访客通行</text>
          <text class="about-section-text">面向来访者的智慧通行解决方案。访客通过微信小程序即可完成实名登记、保安审批、电子凭证亮码、实时位置追踪等全流程操作，实现无纸化、高效化的社区出入管理。</text>
        </view>
        <view class="about-section">
          <text class="about-section-title">邑小区 · 智慧社区</text>
          <text class="about-section-text">面向小区住户的社区生活服务平台。涵盖物业缴费、诉求建议、财务公开、议事协商、信息公示、民生微实事、小区安全、邻里资源共享等功能模块，让社区治理更加透明高效。</text>
        </view>
        <view class="about-section">
          <text class="about-section-title">技术架构</text>
          <text class="about-section-text">基于微信小程序 + 微信云开发原生架构，采用 TDesign 组件库，前后端一体化部署。品牌视觉融合侨乡碉楼文化元素，以暖棕色系打造有温度的社区服务体验。</text>
        </view>
        <view class="about-footer">
          <text class="about-copyright">© 2026 邑易行团队</text>
          <text class="about-copyright">江门市蓬江区</text>
        </view>
      </view>
    </view>
  </t-popup>

  <!-- ====== 弹窗：版本信息 ====== -->
  <t-popup visible="{{versionPopupVisible}}" placement="bottom" bind:close="hideVersion">
    <view class="popup-card">
      <view class="popup-header">
        <text class="popup-title">版本信息</text>
        <text class="popup-close" bindtap="hideVersion">✕</text>
      </view>
      <view class="popup-body version-body">
        <view class="version-row"><text class="version-label">应用名称</text><text class="version-value">邑易行 · 五邑侨乡智慧社区</text></view>
        <view class="version-row"><text class="version-label">版本号</text><text class="version-value">v2.1.0</text></view>
        <view class="version-row"><text class="version-label">更新日期</text><text class="version-value">2026-04-18</text></view>
        <view class="version-divider"></view>
        <view class="version-row"><text class="version-label">前端框架</text><text class="version-value">微信小程序原生</text></view>
        <view class="version-row"><text class="version-label">UI 组件库</text><text class="version-value">TDesign 微信小程序版</text></view>
        <view class="version-row"><text class="version-label">后端服务</text><text class="version-value">微信云开发</text></view>
        <view class="version-row"><text class="version-label">云函数数量</text><text class="version-value">28 个</text></view>
      </view>
    </view>
  </t-popup>

  <t-toast id="t-toast" />
</view>
