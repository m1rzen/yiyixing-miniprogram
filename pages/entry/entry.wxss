.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ── 背景 —— 茶月山式暖粉底 ── */
.bg {
  position: fixed; inset: 0; z-index: 0;
  background: linear-gradient(180deg, #FDF5F0 0%, #FAF0EA 50%, #F5E8DF 100%);
}

/* ── 动画 ── */
.show  { animation: fadeUp .7s ease forwards; }
.delay { animation-delay: .15s; }
.delay2 { animation-delay: .3s; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════════
   上半区：品牌主视觉
   ══════════════════════════════════ */
.hero {
  position: relative; z-index: 2;
  padding: 120rpx 48rpx 0;
  flex: 1;
  opacity: 0;
}

/* 英文标题 */
.hero-en {
  display: block;
  font-size: 38rpx;
  color: #8B7160;
  letter-spacing: 3rpx;
  font-weight: 300;
  font-style: italic;
  font-family: Georgia, 'Times New Roman', serif;
}

/* 方块标签 */
.hero-label {
  display: inline-block;
  background: #5C3D2E;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  margin-top: 16rpx;
  margin-bottom: 36rpx;
}
.hero-label-text {
  font-size: 26rpx;
  color: #FDF5F0;
  letter-spacing: 6rpx;
  font-weight: 600;
}

/* 大标题 */
.hero-title {
  display: block;
  font-size: 52rpx;
  color: #3D2B1F;
  font-weight: 400;
  letter-spacing: 4rpx;
  font-family: Georgia, 'STSong', 'Songti SC', serif;
}

/* ── 碉楼天际线插画 ── */
.hero-visual {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: auto;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  pointer-events: none;
}
.skyline-img {
  width: 100%;
  opacity: 0.85;
}

/* 右侧装饰条 */
.hero-side {
  position: absolute;
  top: 280rpx; right: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  z-index: 5;
}
.color-strip {
  width: 8rpx; height: 80rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #C8963E 0%, #D4A08A 50%, #A0785C 100%);
}
.side-zh {
  font-size: 24rpx;
  color: #8B7160;
  font-weight: 600;
  letter-spacing: 4rpx;
}
.side-en {
  font-size: 20rpx;
  color: #B8A090;
  letter-spacing: 2rpx;
}

/* ══════════════════════════════════
   下半区：双选择
   ══════════════════════════════════ */
.choices {
  position: relative; z-index: 3;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 56rpx 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -4rpx 32rpx rgba(0,0,0,0.03);
  opacity: 0;
}

.choice {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
}
.choice-tap { opacity: 0.5; }

.choice-zh {
  font-size: 48rpx;
  font-weight: 800;
  color: #3D2B1F;
  letter-spacing: 6rpx;
}
.choice-en {
  font-size: 24rpx;
  color: #B8A090;
  letter-spacing: 4rpx;
  font-weight: 500;
  font-family: Georgia, 'Times New Roman', serif;
}

.choice-divider {
  width: 2rpx;
  height: 80rpx;
  background: #E8DDD4;
  flex-shrink: 0;
}

/* ══════════════════════════════════
   底部入口行
   ══════════════════════════════════ */
.bottom-row {
  position: relative; z-index: 3;
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  padding: 16rpx 40rpx 24rpx;
  opacity: 0;
}
.bottom-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.bottom-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
}
.dot-blue  { background: #1D5F8A; }
.dot-gold  { background: #C8963E; }
.dot-green { background: #8FB89A; }
.dot-red   { background: #D4A08A; }

.bottom-label {
  font-size: 24rpx;
  color: #8B7160;
  font-weight: 400;
}

/* 底部英文标语 */
.slogan {
  position: relative; z-index: 3;
  background: #FFFFFF;
  text-align: center;
  padding: 16rpx 0 calc(env(safe-area-inset-bottom) + 32rpx);
  opacity: 0;
}
.slogan-text {
  font-size: 22rpx;
  color: #D4B8A0;
  font-style: italic;
  letter-spacing: 1rpx;
  line-height: 1.6;
  font-family: Georgia, 'Times New Roman', serif;
}
