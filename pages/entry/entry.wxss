.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ── 背景 ── */
.bg {
  position: fixed; inset: 0; z-index: 0;
  background: linear-gradient(180deg, #FDF5F0 0%, #FAF0EA 50%, #F5E8DF 100%);
}

/* ── 动画 ── */
.show  { animation: fadeUp .7s ease forwards; }
.delay { animation-delay: .15s; }
.delay2 { animation-delay: .3s; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════════
   上半区：品牌主视觉
   ══════════════════════════════════ */
.hero {
  position: relative; z-index: 2;
  padding: 120rpx 48rpx 0;
  flex: 1;
  opacity: 0;
}
.hero-en {
  display: block;
  font-size: 38rpx;
  color: #8B7160;
  letter-spacing: 3rpx;
  font-weight: 300;
  font-style: italic;
  font-family: Georgia, 'Times New Roman', serif;
}
.hero-label {
  display: inline-block;
  background: #5C3D2E;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  margin-top: 16rpx;
  margin-bottom: 36rpx;
}
.hero-label-text {
  font-size: 26rpx;
  color: #FDF5F0;
  letter-spacing: 6rpx;
  font-weight: 600;
}
.hero-title {
  display: block;
  font-size: 52rpx;
  color: #3D2B1F;
  font-weight: 400;
  letter-spacing: 4rpx;
  font-family: Georgia, 'STSong', 'Songti SC', serif;
}
.hero-visual {
  position: absolute;
  bottom: 0; left: 0;
  width: 100%; height: auto;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  pointer-events: none;
}
.skyline-img { width: 100%; opacity: 0.85; }
.hero-side {
  position: absolute;
  top: 280rpx; right: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  z-index: 5;
}
.color-strip {
  width: 8rpx; height: 80rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #C8963E 0%, #D4A08A 50%, #A0785C 100%);
}
.side-zh { font-size: 24rpx; color: #8B7160; font-weight: 600; letter-spacing: 4rpx; }
.side-en { font-size: 20rpx; color: #B8A090; letter-spacing: 2rpx; }

/* ══════════════════════════════════
   下半区：双选择
   ══════════════════════════════════ */
.choices {
  position: relative; z-index: 3;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 56rpx 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -4rpx 32rpx rgba(0,0,0,0.03);
  opacity: 0;
}
.choice {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
}
.choice-tap { opacity: 0.5; }
.choice-zh { font-size: 48rpx; font-weight: 800; color: #3D2B1F; letter-spacing: 6rpx; }
.choice-en { font-size: 24rpx; color: #B8A090; letter-spacing: 4rpx; font-weight: 500; font-family: Georgia, 'Times New Roman', serif; }
.choice-divider { width: 2rpx; height: 80rpx; background: #E8DDD4; flex-shrink: 0; }

/* ══════════════════════════════════
   底部快捷入口
   ══════════════════════════════════ */
.bottom-row {
  position: relative; z-index: 3;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 32rpx 40rpx;
  opacity: 0;
}
.bottom-item { padding: 12rpx 0; }
.bottom-item:active { opacity: 0.5; }
.bottom-dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: #D4C4B0;
}
.bottom-label {
  font-size: 24rpx;
  color: #A09486;
  font-weight: 400;
  letter-spacing: 2rpx;
}

/* 底部英文标语 */
.slogan {
  position: relative; z-index: 3;
  background: #FFFFFF;
  text-align: center;
  padding: 16rpx 0 calc(env(safe-area-inset-bottom) + 32rpx);
  opacity: 0;
}
.slogan-text {
  font-size: 22rpx;
  color: #D4B8A0;
  font-style: italic;
  letter-spacing: 1rpx;
  line-height: 1.6;
  font-family: Georgia, 'Times New Roman', serif;
  white-space: pre-line;
}

/* ══════════════════════════════════
   弹窗通用
   ══════════════════════════════════ */
.popup-card {
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 32rpx);
  max-height: 80vh;
  overflow-y: auto;
}
.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 24rpx;
  border-bottom: 2rpx solid #EDE4DB;
  position: sticky;
  top: 0;
  background: #FFF;
  z-index: 1;
}
.popup-title { font-size: 36rpx; font-weight: 800; color: #3D2B1F; }
.popup-close {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #A09486;
  background: #F5EDE5;
  border-radius: 50%;
}
.popup-close:active { background: #EDE4DB; }
.popup-body { padding: 28rpx 0; }

/* ── 关于我们 ── */
.about-body { padding-bottom: 20rpx; }
.about-logo {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}
.about-logo-dot {
  width: 32rpx; height: 32rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8963E, #A67930);
}
.about-logo-text {
  font-size: 32rpx;
  color: #3D2B1F;
  font-weight: 800;
  letter-spacing: 4rpx;
}
.about-appname {
  display: block;
  font-size: 26rpx;
  color: #6B5E50;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}
.about-divider {
  width: 48rpx; height: 4rpx;
  background: linear-gradient(90deg, #C8963E, transparent);
  border-radius: 2rpx;
  margin-bottom: 24rpx;
}
.about-desc {
  display: block;
  font-size: 28rpx;
  color: #5C3D2E;
  line-height: 1.8;
  letter-spacing: 1rpx;
  margin-bottom: 28rpx;
}
.about-section { margin-bottom: 24rpx; }
.about-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 12rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #C8963E;
}
.about-section-text {
  display: block;
  font-size: 26rpx;
  color: #6B5E50;
  line-height: 1.7;
}
.about-footer {
  text-align: center;
  padding: 20rpx 0;
  border-top: 2rpx solid #EDE4DB;
}
.about-copyright {
  display: block;
  font-size: 22rpx;
  color: #B8A090;
  letter-spacing: 1rpx;
}

/* ── 版本信息 ── */
.version-body { padding-bottom: 20rpx; }
.version-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5EDE5;
}
.version-row:last-child { border-bottom: none; }
.version-label { font-size: 28rpx; color: #A09486; }
.version-value { font-size: 28rpx; color: #3D2B1F; font-weight: 500; }
.version-divider { width: 100%; height: 2rpx; background: #EDE4DB; margin: 8rpx 0; }
