.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* ── 背景 ── */
.bg {
  position: fixed; inset: 0;
  background: #F6F3EF;
  z-index: 1;
}
.orb {
  position: fixed;
  border-radius: 50%;
  z-index: 2;
}
.orb-a {
  width: 520rpx; height: 520rpx;
  top: -80rpx; right: -140rpx;
  background: radial-gradient(circle, rgba(200,150,62,0.12) 0%, transparent 65%);
  filter: blur(80rpx);
}
.orb-b {
  width: 440rpx; height: 440rpx;
  bottom: 40rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(29,95,138,0.08) 0%, transparent 65%);
  filter: blur(80rpx);
}

/* ── 动画 ── */
.show { animation: up .65s ease forwards; }
.delay { animation-delay: .12s; }
.delay2 { animation-delay: .25s; }
@keyframes up {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── 头部 ── */
.top {
  position: relative; z-index: 10;
  width: 100%;
  padding: 0 56rpx;
  margin-bottom: 72rpx;
  opacity: 0;
}
.brand-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255,255,255,0.65);
  padding: 10rpx 24rpx 10rpx 16rpx;
  border-radius: 100rpx;
  backdrop-filter: blur(16px);
  border: 1rpx solid rgba(0,0,0,0.03);
  margin-bottom: 40rpx;
}
.brand-dot {
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  background: #C8963E;
}
.brand-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #4A3C2C;
  letter-spacing: 3rpx;
}
.greeting {
  display: block;
  font-size: 28rpx;
  color: #A89A8A;
  margin-bottom: 8rpx;
}
.title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #2C2419;
  letter-spacing: 2rpx;
}

/* ── 双卡片 ── */
.cards {
  position: relative; z-index: 10;
  width: 100%;
  padding: 0 40rpx;
  display: flex;
  gap: 24rpx;
  opacity: 0;
}
.card {
  flex: 1;
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(20px);
  border-radius: 32rpx;
  padding: 40rpx 32rpx 36rpx;
  border: 1rpx solid rgba(255,255,255,0.95);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  transition: transform .15s ease, box-shadow .15s ease;
}
.card-tap {
  transform: scale(0.97) !important;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06) !important;
}

/* 图标 */
.card-icon {
  width: 88rpx; height: 88rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}
.icon-blue {
  background: linear-gradient(140deg, #2476A8 0%, #134566 100%);
  box-shadow: 0 8rpx 20rpx rgba(29,95,138,0.25);
}
.icon-gold {
  background: linear-gradient(140deg, #D4A64A 0%, #A67930 100%);
  box-shadow: 0 8rpx 20rpx rgba(200,150,62,0.25);
}

/* 文字 */
.card-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #2C2419;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}
.card-desc {
  font-size: 24rpx;
  color: #A89A8A;
  font-weight: 400;
  margin-bottom: 44rpx;
}

/* 箭头按钮 */
.card-arrow {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: auto;
  align-self: flex-end;
}
.arrow-blue {
  background: linear-gradient(140deg, #2476A8, #134566);
  box-shadow: 0 4rpx 16rpx rgba(29,95,138,0.3);
}
.arrow-gold {
  background: linear-gradient(140deg, #D4A64A, #A67930);
  box-shadow: 0 4rpx 16rpx rgba(200,150,62,0.3);
}

/* ── 底部 ── */
.bottom {
  position: relative; z-index: 10;
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  opacity: 0;
}
.bottom-line {
  width: 48rpx; height: 3rpx;
  border-radius: 2rpx;
  background: #D6CBBD;
}
.bottom-text {
  font-size: 22rpx;
  color: #B8AA98;
  letter-spacing: 2rpx;
}
