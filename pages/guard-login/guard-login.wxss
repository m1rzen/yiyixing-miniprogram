.guard-login-page {
  min-height: 100vh;
  position: relative;
}

.bg-gradient {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(170deg, #0A2538 0%, #0C2E45 35%, #1D5F8A 100%);
  z-index: 1;
}
.bg-pattern {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 2; opacity: 0.04;
  background-image: radial-gradient(circle at 25% 25%, #FFF 1px, transparent 1px);
  background-size: 60px 60px;
}

.content {
  position: relative; z-index: 3;
  padding: 0 36rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 品牌 */
.guard-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0 44rpx;
}
.guard-icon {
  width: 120rpx; height: 120rpx;
  border-radius: 30rpx;
  background: rgba(200,150,62,0.15);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(200,150,62,0.2);
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.2);
}
.guard-brand-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFF;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}
.guard-brand-desc {
  font-size: 26rpx;
  color: rgba(200,150,62,0.6);
  letter-spacing: 2rpx;
}

/* 登录卡片 */
.login-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  padding: 44rpx 36rpx;
  box-shadow: var(--shadow-lg);
}
.form-group { margin-bottom: 28rpx; }
.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  display: block;
  margin-bottom: 14rpx;
}
.input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 96rpx;
  padding: 0 28rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.input-wrap:focus-within {
  border-color: var(--brand-color);
  background: #FFF;
  box-shadow: 0 0 0 4rpx rgba(29,95,138,0.08);
}
.form-input {
  flex: 1; height: 100%;
  background: transparent;
  border: none;
  font-size: 30rpx;
  color: var(--text-primary);
}
.eye-btn { padding: 8rpx; }
.eye-btn:active { opacity: 0.6; }

.login-btn {
  margin-top: 16rpx;
  height: 100rpx !important;
  border-radius: 24rpx !important;
  font-size: 34rpx !important;
}

.login-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 28rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}
