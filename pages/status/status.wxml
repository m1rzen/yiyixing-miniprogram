<view class="status-page">
  <view class="bg-top"></view>

  <view class="content immersive-content">
    <view class="custom-nav">
      <view class="nav-back" bindtap="goHome">
        <t-icon name="home" size="40rpx" color="#FFF" />
      </view>
      <text class="nav-title">通行凭证</text>
    </view>

    <!-- 加载中 -->
    <view class="loading-card" wx:if="{{status === 'loading'}}">
      <t-loading theme="circular" size="80rpx" />
      <text class="loading-text">加载凭证中...</text>
    </view>

    <!-- 错误状态 -->
    <view class="pass-card" wx:if="{{status === 'error'}}">
      <view class="pass-status-area rejected-bg">
        <view class="status-ring rejected-ring">
          <t-icon name="close-circle-filled" size="80rpx" color="#C94545" />
        </view>
        <text class="pass-status-title rejected-text">加载失败</text>
        <text class="pass-status-desc">无法获取通行凭证，请检查网络后重试</text>
      </view>
      <view class="pass-action-area">
        <t-button t-class="btn-secondary refresh-btn" bindtap="handleRetry">
          重新加载
        </t-button>
      </view>
    </view>

    <view class="pass-card" wx:if="{{status !== 'loading' && status !== 'error'}}">
      <!-- 审核中 -->
      <block wx:if="{{status === 'pending'}}">
        <view class="pass-status-area pending-bg">
          <view class="status-ring pending-ring pulse-ring">
            <t-icon name="time-filled" size="80rpx" color="#C8963E" />
          </view>
          <text class="pass-status-title pending-text">审核中</text>
          <text class="pass-status-desc">您的入区申请正在等待保安审批</text>
          <view class="polling-hint">
            <view class="polling-dot"></view>
            <text>自动刷新中，无需手动操作</text>
          </view>
        </view>
        <view class="pass-action-area">
          <t-button t-class="btn-secondary refresh-btn" loading="{{isRefreshing}}" bindtap="handleRefresh">
            {{isRefreshing ? '刷新中...' : '手动刷新'}}
          </t-button>
        </view>
      </block>

      <!-- 已通过 — 通行凭证 -->
      <block wx:if="{{status === 'approved'}}">
        <view class="pass-status-area approved-bg">
          <view class="status-ring approved-ring">
            <t-icon name="check-circle-filled" size="80rpx" color="#2D8B6F" />
          </view>
          <text class="pass-status-title approved-text">准予通行</text>
          <text class="pass-status-desc">请向门岗保安出示此通行凭证</text>
        </view>

        <!-- 通行凭证主体 -->
        <view class="pass-credential">
          <!-- 大号凭证编号 -->
          <view class="pass-id-area">
            <text class="pass-id-label">通行凭证编号</text>
            <text class="pass-id-code">{{passCode}}</text>
          </view>

          <!-- 准予通行印章 -->
          <view class="pass-stamp">
            <view class="stamp-ring">
              <text class="stamp-text">准予</text>
              <text class="stamp-text">通行</text>
            </view>
          </view>

          <!-- 访客信息摘要 -->
          <view class="pass-info-grid">
            <view class="pass-info-item">
              <text class="pi-label">访客姓名</text>
              <text class="pi-value">{{visit.visitorName || '-'}}</text>
            </view>
            <view class="pass-info-item">
              <text class="pi-label">目的小区</text>
              <text class="pi-value">{{visit.community || '-'}}</text>
            </view>
            <view class="pass-info-item">
              <text class="pi-label">拜访事由</text>
              <text class="pi-value">{{visit.reason || '-'}}</text>
            </view>
            <view class="pass-info-item">
              <text class="pi-label">有效期至</text>
              <text class="pi-value highlight">今日 23:59</text>
            </view>
          </view>

          <!-- 动态验证码 -->
          <view class="pass-verify-bar">
            <view class="verify-dot active"></view>
            <text class="verify-label">实时验证码</text>
            <text class="verify-code">{{verifyCode}}</text>
            <text class="verify-timer">{{verifyCountdown}}s 后刷新</text>
          </view>
        </view>

        <!-- 平台认证标识 -->
        <view class="platform-badge-row" wx:if="{{visit.platform && visit.platform !== '普通访客'}}">
          <view class="platform-verified-badge">
            <t-icon name="check-circle-filled" size="28rpx" color="#2D8B6F" />
            <text>{{visit.platform}} · 平台身份已核验</text>
          </view>
        </view>

        <view class="pass-quick-actions">
          <view class="pqa-btn" bindtap="goToTracking">
            <t-icon name="map-information" size="36rpx" color="#1D5F8A" />
            <text>位置打卡</text>
          </view>
          <view class="pqa-btn danger" bindtap="goToSignout">
            <t-icon name="logout" size="36rpx" color="#C94545" />
            <text>签退离场</text>
          </view>
        </view>
      </block>

      <!-- 已驳回 -->
      <block wx:if="{{status === 'rejected'}}">
        <view class="pass-status-area rejected-bg">
          <view class="status-ring rejected-ring">
            <t-icon name="close-circle-filled" size="80rpx" color="#C94545" />
          </view>
          <text class="pass-status-title rejected-text">申请被驳回</text>
          <text class="pass-status-desc">{{visit.rejectReason || '您的入区申请未通过审核'}}</text>
        </view>
        <view class="pass-action-area">
          <t-button t-class="btn-primary reapply-btn" bindtap="handleReapply">
            重新申请
          </t-button>
        </view>
      </block>

      <!-- 已签退 -->
      <block wx:if="{{status === 'completed'}}">
        <view class="pass-status-area completed-bg">
          <view class="status-ring completed-ring">
            <t-icon name="check-circle" size="80rpx" color="#9CA3AF" />
          </view>
          <text class="pass-status-title completed-text">已签退</text>
          <text class="pass-status-desc">本次拜访已结束，感谢您的配合</text>
        </view>
      </block>

      <!-- 票根分割线 -->
      <view class="ticket-divider">
        <view class="punch left"></view>
        <view class="dash-line"></view>
        <view class="punch right"></view>
      </view>

      <!-- 拜访详情 -->
      <view class="detail-section" wx:if="{{visit}}">
        <text class="detail-label">— 拜访详情 —</text>
        <view class="detail-row">
          <text class="dr-key">小区名称</text>
          <text class="dr-val">{{visit.community || '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="dr-key">拜访事由</text>
          <text class="dr-val">{{visit.reason || '-'}}</text>
        </view>
        <view class="detail-row" wx:if="{{visit.platform && visit.platform !== '普通访客'}}">
          <text class="dr-key">平台认证</text>
          <text class="dr-val platform-text">{{visit.platform}}</text>
        </view>
        <view class="detail-row">
          <text class="dr-key">申请时间</text>
          <text class="dr-val">{{currentTime}}</text>
        </view>
        <view class="detail-row" wx:if="{{visit.approvedBy && visit.approvedBy !== 'system'}}">
          <text class="dr-key">审批人</text>
          <text class="dr-val">{{visit.approvedBy}}</text>
        </view>
      </view>
    </view>

    <view class="bottom-area safe-bottom">
      <t-button block t-class="btn-primary" bindtap="goHome">返回首页</t-button>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
