.status-page {
  min-height: 100vh;
  position: relative;
  background: var(--bg-primary);
}

.bg-top {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 400rpx;
  background: linear-gradient(170deg, #0C2E45 0%, #1D5F8A 45%, #134566 100%);
  z-index: 1;
}

.content {
  position: relative; z-index: 3;
  padding: 0 28rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 加载中 */
.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 160rpx 0 80rpx;
}
.loading-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

/* 通行证卡片 */
.pass-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
  margin-bottom: 24rpx;
}

/* 状态区域 */
.pass-status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 52rpx 36rpx 36rpx;
}
.pending-bg { background: linear-gradient(180deg, var(--qiao-gold-light) 0%, #FFF 100%); }
.approved-bg { background: linear-gradient(180deg, var(--qiao-jade-light) 0%, #FFF 100%); }
.rejected-bg { background: linear-gradient(180deg, var(--danger-light) 0%, #FFF 100%); }
.completed-bg { background: linear-gradient(180deg, #F5F5F5 0%, #FFF 100%); }

.status-ring {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.pending-ring { background: rgba(200,150,62,0.1); }
.approved-ring {
  background: rgba(45,139,111,0.1);
  animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.rejected-ring { background: rgba(201,69,69,0.1); }
.completed-ring { background: rgba(156,163,175,0.1); }

.pulse-ring { animation: ringPulse 2s ease-in-out infinite; }
@keyframes ringPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(200,150,62,0.2); }
  50% { box-shadow: 0 0 0 16rpx rgba(200,150,62,0.05); }
}

.pass-status-title {
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}
.pending-text { color: var(--warning-color); }
.approved-text { color: var(--success-color); }
.rejected-text { color: var(--danger-color); }
.completed-text { color: var(--text-tertiary); }
.pass-status-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
}

/* 轮询提示 */
.polling-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.polling-dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: var(--warning-color);
  animation: blink 1.5s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.pass-action-area {
  padding: 24rpx 36rpx 36rpx;
  display: flex;
  justify-content: center;
  gap: 16rpx;
}
.refresh-btn {
  width: 280rpx !important;
  border-radius: 100rpx !important;
}
.reapply-btn {
  width: 280rpx !important;
  border-radius: 100rpx !important;
  height: 88rpx !important;
}

/* ===== 通行凭证主体 ===== */
.pass-credential {
  position: relative;
  margin: 0 36rpx 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #F0FAF6 0%, #E8F5F0 50%, #F0FAF6 100%);
  border: 3rpx solid rgba(45,139,111,0.2);
  border-radius: var(--radius-lg);
}

/* 凭证编号 */
.pass-id-area {
  text-align: center;
  margin-bottom: 24rpx;
}
.pass-id-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 8rpx;
}
.pass-id-code {
  font-size: 52rpx;
  font-weight: 800;
  color: #1A1A2E;
  letter-spacing: 12rpx;
  font-family: monospace;
}

/* 准予通行印章 */
.pass-stamp {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(15deg);
  opacity: 0.7;
}
.stamp-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 5rpx solid #2D8B6F;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.stamp-text {
  font-size: 28rpx;
  font-weight: 900;
  color: #2D8B6F;
  line-height: 1.2;
  letter-spacing: 4rpx;
}

/* 访客信息网格 */
.pass-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.pass-info-item {
  background: rgba(255,255,255,0.8);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.pi-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-bottom: 4rpx;
}
.pi-value {
  display: block;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.pi-value.highlight {
  color: var(--success-color);
}

/* 动态验证码 */
.pass-verify-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(29,95,138,0.06);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.verify-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: #D1D5DB;
  flex-shrink: 0;
}
.verify-dot.active {
  background: var(--success-color);
  animation: blink 1.5s ease-in-out infinite;
}
.verify-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}
.verify-code {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--brand-color);
  letter-spacing: 8rpx;
  font-family: monospace;
  margin-left: auto;
}
.verify-timer {
  font-size: 20rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

/* 平台认证标识 */
.platform-badge-row {
  padding: 0 36rpx 16rpx;
  display: flex;
  justify-content: center;
}
.platform-verified-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(45,139,111,0.08);
  border: 1rpx solid rgba(45,139,111,0.15);
  border-radius: 100rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: var(--success-color);
  font-weight: 500;
}

/* 快捷操作 */
.pass-quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 36rpx 28rpx;
}
.pqa-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-lg);
  background: var(--bg-primary);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand-color);
}
.pqa-btn.danger { color: var(--danger-color); }
.pqa-btn:active { background: var(--bg-hover); }

/* 票根分割线 */
.ticket-divider {
  width: 100%; height: 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  margin: 8rpx 0;
}
.punch {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  position: absolute;
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.punch.left { left: -20rpx; }
.punch.right { right: -20rpx; }
.dash-line {
  flex: 1;
  margin: 0 30rpx;
  border-top: 2rpx dashed var(--border-color);
}

/* 详情区 */
.detail-section { padding: 28rpx 36rpx 36rpx; }
.detail-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}
.detail-row:last-child { margin-bottom: 0; }
.dr-key { font-size: 28rpx; color: var(--text-tertiary); }
.dr-val {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}
.dr-val.platform-text { color: var(--brand-color); }

/* 底部 */
.bottom-area {
  margin-top: auto;
  padding: 32rpx 0;
}

@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
