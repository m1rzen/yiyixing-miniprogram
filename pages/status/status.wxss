/* pages/status/status.wxss */
.status-page { 
  min-height: 100vh; 
  position: relative; 
  background-color: #F0F2F5; 
  display: flex;
  flex-direction: column;
}

/* 沉浸式背景层 */
.chikan-bg-full { position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 1; }
.bg-overlay-full { 
  position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 2; 
  background: linear-gradient(180deg, rgba(38, 85, 109, 0.95) 0%, rgba(240, 242, 245, 0.2) 40%, rgba(240, 242, 245, 0.9) 100%); 
}

/* 主体内边距与布局 */
.content-wrap { 
  position: relative; 
  z-index: 3; 
  padding: 0 40rpx; 
  display: flex; 
  flex-direction: column; 
  flex: 1;
  min-height: 100vh; 
}

/* 顶部自定义导航 */
.nav-bar { display: flex; align-items: center; padding-top: 100rpx; margin-bottom: 40rpx; }
.back-btn { width: 80rpx; height: 80rpx; display: flex; align-items: center; justify-content: flex-start; }
.nav-title { font-size: 36rpx; font-weight: 600; color: #FFF; margin-left: -20rpx; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1); }

/* 核心毛玻璃卡片 */
.main-glass-card { 
  width: 100%;
  box-sizing: border-box;
  border-radius: 40rpx; 
  padding: 60rpx 40rpx 40rpx; 
  margin-bottom: 60rpx; 
  background: rgba(255, 255, 255, 0.85); 
  backdrop-filter: blur(25px); 
  border: 2rpx solid #FFFFFF; 
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.1); 
  display: flex; 
  flex-direction: column; 
  align-items: center;
}
.text-center { text-align: center; }

/* 状态图标与阴影 */
.status-icon-wrap { margin-bottom: 30rpx; transition: all 0.3s ease; display: flex; justify-content: center; }
.wait-shadow { filter: drop-shadow(0 8rpx 16rpx rgba(63, 141, 180, 0.3)); }
.success-shadow { filter: drop-shadow(0 8rpx 16rpx rgba(0, 168, 112, 0.3)); animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }

/* 状态文字 */
.status-title { font-size: 40rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 16rpx; letter-spacing: 2rpx; text-align: center; width: 100%;}
.success-color { color: #00A870; }
.status-desc { font-size: 28rpx; color: #666; font-weight: 400; margin-bottom: 50rpx; text-align: center; width: 100%;}

/* 🌟 核心修复：刷新按钮样式，锁定宽高防止变形 */
.refresh-btn-safe {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx; 
  width: 380rpx; 
  height: 88rpx; 
  margin: 0 auto 40rpx auto;
  border-radius: 100rpx;
  background: rgba(63, 141, 180, 0.08);
  border: 2rpx solid #3F8DB4;
  color: #3F8DB4;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s;
}
.btn-hover {
  background: rgba(63, 141, 180, 0.15);
  transform: scale(0.96);
}
.spin-icon { animation: spin 1s linear infinite; display: inline-block; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

/* 二维码区域 */
.qr-code-box { display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx; animation: fadeIn 0.5s ease; width: 100%; }
.qr-corners { 
  padding: 30rpx; background: #FFF; border-radius: 20rpx; 
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); border: 2rpx solid rgba(0,0,0,0.05);
  position: relative;
  display: flex; justify-content: center; align-items: center;
}
.qr-corners::before, .qr-corners::after { content: ''; position: absolute; width: 40rpx; height: 40rpx; border: 6rpx solid #00A870; }
.qr-corners::before { top: 10rpx; left: 10rpx; border-right: none; border-bottom: none; border-radius: 12rpx 0 0 0; }
.qr-corners::after { bottom: 10rpx; right: 10rpx; border-left: none; border-top: none; border-radius: 0 0 12rpx 0; }
.valid-time { margin-top: 24rpx; font-size: 24rpx; color: #888; background: #F0F2F5; padding: 6rpx 20rpx; border-radius: 100rpx; }

/* 票根打孔分割线 */
.divider-wrap { width: calc(100% + 80rpx); margin-left: -40rpx; height: 40rpx; display: flex; align-items: center; position: relative; margin-bottom: 40rpx; margin-top: 10rpx;}
.dashed-line { flex: 1; height: 0; border-top: 2rpx dashed rgba(0,0,0,0.1); margin: 0 30rpx; }
.half-circle { width: 40rpx; height: 40rpx; background-color: #F0F2F5; border-radius: 50%; position: absolute; box-shadow: inset 0 4rpx 8rpx rgba(0,0,0,0.05); }
.half-circle.left { left: -20rpx; }
.half-circle.right { right: -20rpx; }

/* 详情区 */
.detail-title { font-size: 28rpx; color: #999; margin-bottom: 30rpx; width: 100%; text-align: center; letter-spacing: 4rpx;}
.detail-list { width: 100%; padding: 0 20rpx; box-sizing: border-box; }
.detail-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; width: 100%;}
.detail-row:last-child { margin-bottom: 0; }
.d-label { font-size: 28rpx; color: #666; }
.d-value { font-size: 30rpx; color: #1A1A1A; font-weight: 500; text-align: right;}

/* 底部返回首页按钮区 */
.bottom-action { margin-top: auto; padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx); width: 100%; }
.glass-submit-btn { 
  background: linear-gradient(135deg, #3F8DB4 0%, #2A6685 100%) !important; 
  color: #FFF !important; border-radius: 24rpx !important; height: 100rpx !important; box-shadow: 0 16rpx 40rpx rgba(63, 141, 180, 0.3) !important; border: none !important; font-size: 32rpx !important; letter-spacing: 2rpx;
  display: flex !important; justify-content: center !important; align-items: center !important; width: 100% !important;
}

/* 动效 */
@keyframes popIn { 0% { transform: scale(0.5); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
@keyframes fadeIn { 0% { opacity: 0; transform: translateY(20rpx); } 100% { opacity: 1; transform: translateY(0); } }