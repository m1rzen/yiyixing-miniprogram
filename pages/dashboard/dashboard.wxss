.dashboard-page {
  min-height: 100vh;
  position: relative;
}

.home-float-btn {
  position: fixed; top: 100rpx; left: 28rpx;
  z-index: 100;
  width: 68rpx; height: 68rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.12);
}
.home-float-btn:active { background: rgba(255,255,255,0.3); }

.bg-gradient {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 520rpx;
  background: linear-gradient(170deg, #0C2E45 0%, #1D5F8A 45%, #134566 100%);
  z-index: 1;
}
.bg-pattern {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 520rpx;
  z-index: 2; opacity: 0.04;
  background-image: radial-gradient(circle at 30% 30%, #FFF 1px, transparent 1px);
  background-size: 50px 50px;
}

.content {
  position: relative; z-index: 3;
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ========== 用户栏 ========== */
.user-bar {
  display: flex;
  align-items: center;
  margin-top: 120rpx;
  margin-bottom: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255,255,255,0.12);
}
.user-bar:active { background: rgba(255,255,255,0.18); }
.avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: 2rpx solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.avatar-img {
  width: 100%; height: 100%;
}
.user-text { flex: 1; }
.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFF;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.role-tag {
  font-size: 20rpx;
  background: rgba(200,150,62,0.85);
  color: #FFF;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 400;
}
.user-phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

/* ========== 文化标语 ========== */
.culture-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.culture-dot {
  width: 6rpx; height: 6rpx;
  border-radius: 50%;
  background: rgba(200,150,62,0.5);
}
.culture-text {
  font-size: 22rpx;
  color: rgba(200,150,62,0.6);
  letter-spacing: 4rpx;
  font-weight: 500;
}

/* ========== 小区选择栏 ========== */
.community-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-lg);
  background: #FFF;
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
}
.community-bar:active { background: var(--bg-hover); }
.community-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.community-icon-wrap {
  width: 52rpx; height: 52rpx;
  border-radius: 14rpx;
  background: var(--brand-color);
  display: flex;
  align-items: center;
  justify-content: center;
}
.community-info {
  display: flex;
  flex-direction: column;
}
.community-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.community-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.community-switch {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: var(--brand-color);
  font-weight: 500;
}

/* ========== 活跃访问卡片 ========== */
.active-visit-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
}
.avc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.avc-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.avc-status-text {
  font-size: 30rpx;
  font-weight: 700;
}
.avc-status.pending .avc-status-text { color: var(--warning-color); }
.avc-status.approved .avc-status-text { color: var(--success-color); }
.avc-community {
  font-size: 26rpx;
  color: var(--text-tertiary);
}
.avc-info {
  padding: 20rpx 0;
  border-top: 2rpx solid var(--border-color);
  border-bottom: 2rpx solid var(--border-color);
  margin-bottom: 24rpx;
}
.avc-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.avc-row:last-child { margin-bottom: 0; }
.avc-label { font-size: 28rpx; color: var(--text-tertiary); }
.avc-value { font-size: 28rpx; color: var(--text-primary); font-weight: 500; }
.avc-actions { display: flex; gap: 16rpx; }
.avc-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
.avc-btn:active { background: var(--bg-hover); }
.avc-btn-icon {
  width: 52rpx; height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avc-btn-icon.blue { background: var(--brand-color); }
.avc-btn-icon.green { background: var(--success-color); }
.avc-btn-icon.red { background: var(--danger-color); }

/* ========== 主操作卡片 ========== */
.main-card {
  background: #FFF;
  border-radius: var(--radius-xl);
  padding: 44rpx 36rpx;
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
}
.mc-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}
.mc-icon-wrap { margin-bottom: 16rpx; }
.mc-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.mc-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
.register-btn {
  height: 100rpx !important;
  border-radius: 24rpx !important;
  font-size: 34rpx !important;
  margin-bottom: 36rpx;
}

/* 平台按钮 */
.platform-row { display: flex; gap: 16rpx; }
.platform-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-lg);
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
  background: var(--bg-primary);
}
.platform-btn:active { transform: scale(0.95); }
.platform-btn.meituan { color: #FF9800; }
.platform-btn.shunfeng { color: #D32F2F; }
.platform-btn.jingdong { color: #E53935; }
.platform-icon-wrap {
  width: 64rpx; height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 底部 ========== */
.bottom-area {
  margin-top: auto;
  padding: 40rpx 0 calc(env(safe-area-inset-bottom) + 40rpx);
  display: flex;
  justify-content: center;
}
.logout-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 40rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(10px);
  font-size: 26rpx;
  color: var(--text-tertiary);
  box-shadow: var(--shadow-sm);
}
.logout-btn:active { background: #FFF; }

/* ========== 平台弹窗 ========== */
.platform-popup {
  background: #FFF;
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
}
.pp-header {
  padding: 44rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.gradient-meituan { background: linear-gradient(135deg, #FFC107 0%, #FF9800 100%); }
.gradient-shunfeng { background: linear-gradient(135deg, #EF5350 0%, #C62828 100%); }
.gradient-jingdong { background: linear-gradient(135deg, #E53935 0%, #B71C1C 100%); }
.pp-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.pp-brand-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFF;
  letter-spacing: 2rpx;
}
.pp-header-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}
.pp-body {
  padding: 36rpx 36rpx calc(env(safe-area-inset-bottom) + 30rpx);
}
.pp-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 16rpx;
}
.bold {
  font-weight: 700;
  color: var(--text-primary);
}
.text-meituan { color: #FF9800 !important; }
.text-shunfeng { color: #D32F2F !important; }
.text-jingdong { color: #E53935 !important; }
.pp-tip {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 36rpx;
}
.pp-actions { display: flex; gap: 24rpx; }
.pp-btn {
  flex: 1; height: 96rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}
.pp-btn.cancel {
  background: var(--bg-primary);
  color: var(--text-secondary);
}
.pp-btn.confirm { color: #FFF; }
.btn-meituan { background: linear-gradient(135deg, #FFC107 0%, #FF9800 100%); }
.btn-shunfeng { background: linear-gradient(135deg, #EF5350 0%, #C62828 100%); }
.btn-jingdong { background: linear-gradient(135deg, #E53935 0%, #B71C1C 100%); }
.pp-btn:active { opacity: 0.9; transform: scale(0.98); }

/* 加载占位 */
.loading-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 80rpx 0;
}
.loading-placeholder-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}
