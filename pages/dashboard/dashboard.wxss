.dashboard-page { min-height: 100vh; position: relative; background-color: #F0F2F5; }

/* 沉浸式背景层 */
.chikan-bg-full { position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 1; }
.bg-overlay-full { 
  position: fixed; left: 0; top: 0; width: 100%; height: 100vh; z-index: 2; 
  background: linear-gradient(180deg, rgba(38, 85, 109, 0.85) 0%, rgba(255, 255, 255, 0.2) 40%, rgba(255, 255, 255, 0.6) 100%); 
}

/* 用户栏点击微动效 */
.glass-hover { background: rgba(255, 255, 255, 0.35) !important; transform: scale(0.98); }

.content-wrap { position: relative; z-index: 3; padding: 0 40rpx; display: flex; flex-direction: column; min-height: 100vh; }
.safe-top-spacer { height: 120rpx; }

/* 基础毛玻璃 */
.user-header-glass { 
  display: flex; align-items: center; margin-bottom: 50rpx; padding: 24rpx 30rpx; border-radius: 100rpx; 
  background: rgba(255, 255, 255, 0.25); backdrop-filter: blur(15px); border: 2rpx solid rgba(255, 255, 255, 0.4); box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}
.avatar-wrap { width: 90rpx; height: 90rpx; background: rgba(255, 255, 255, 0.2); border-radius: 50%; display: flex; justify-content: center; align-items: center; margin-right: 24rpx; border: 2rpx solid rgba(255, 255, 255, 0.5); }
.user-info { display: flex; flex-direction: column; color: #FFF; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.15); }
.user-name { font-size: 34rpx; font-weight: 600; display: flex; align-items: center; margin-bottom: 6rpx; }
.role-tag-warm { font-size: 20rpx; background: rgba(255, 152, 0, 0.9); color: #FFF; padding: 2rpx 12rpx; border-radius: 8rpx; margin-left: 12rpx; font-weight: 400; text-shadow: none; }
.user-phone { font-size: 26rpx; color: rgba(255, 255, 255, 0.9); display: flex; align-items: center; gap: 4rpx; }

.main-glass-card { 
  border-radius: 40rpx; padding: 50rpx 40rpx; margin-bottom: 40rpx; 
  background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(25px); border: 2rpx solid #FFFFFF; box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.1); 
}

.location-bar { display: flex; justify-content: center; align-items: center; margin-bottom: 60rpx; position: relative; }
.loc-left { display: flex; align-items: center; gap: 10rpx; }
.community-name { font-size: 36rpx; font-weight: 600; color: #1A1A1A; }
.switch-btn-transparent { position: absolute; right: 0; font-size: 24rpx; color: #3F8DB4; background: rgba(63, 141, 180, 0.1); border: 2rpx solid rgba(63, 141, 180, 0.2); padding: 6rpx 20rpx; border-radius: 100rpx; font-weight: 500;}

.status-area { display: flex; flex-direction: column; align-items: center; margin-bottom: 80rpx; }
.status-icon-wrap { margin-bottom: 30rpx; filter: drop-shadow(0 4rpx 12rpx rgba(63, 141, 180, 0.3)); }
.status-title-dark { font-size: 42rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 16rpx; }
.status-desc-mid { font-size: 30rpx; color: #666; font-weight: 400; }

.glass-submit-btn { 
  background: linear-gradient(135deg, #3F8DB4 0%, #2A6685 100%) !important; color: #FFF !important; border-radius: 20rpx !important; margin-bottom: 60rpx; box-shadow: 0 12rpx 30rpx rgba(63, 141, 180, 0.4) !important; border: none !important;
}

.divider-wrap-dim { display: flex; align-items: center; justify-content: center; margin-bottom: 40rpx; }
.line { width: 100rpx; height: 2rpx; background: rgba(0, 0, 0, 0.08); }
.divider-text { font-size: 24rpx; color: #999; margin: 0 24rpx; }

.quick-actions-row-transparent { display: flex; justify-content: space-between; gap: 18rpx; }
.quick-btn-glass { 
  flex: 1; height: 84rpx; border-radius: 18rpx; display: flex; justify-content: center; align-items: center; font-size: 26rpx; font-weight: 600; background: rgba(255, 255, 255, 0.9); border: 2rpx solid rgba(0, 0, 0, 0.05); box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03); transition: transform 0.2s; 
}
.quick-btn-glass:active { transform: scale(0.96); }
.meituan-t { color: #FF9800; border-color: rgba(255, 152, 0, 0.2); }
.shunfeng-t { color: #D32F2F; border-color: rgba(211, 47, 47, 0.2); }
.jingdong-t { color: #E53935; border-color: rgba(229, 57, 53, 0.2); }

.bottom-actions { margin-top: auto; padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx); display: flex; flex-direction: column; align-items: center; gap: 30rpx; }
.delete-btn-glass { 
  width: 100%; height: 96rpx; border-radius: 20rpx; display: flex; justify-content: center; align-items: center; font-size: 30rpx; font-weight: 500; color: #333; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px); border: 2rpx solid #FFFFFF; box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06); transition: all 0.2s;
}
.delete-btn-glass:active { background: rgba(255, 255, 255, 1); transform: scale(0.98); }
.del-icon { margin-right: 12rpx; opacity: 0.8; }
.logout-btn-glass { padding: 16rpx 40rpx; border-radius: 100rpx; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(15px); border: 2rpx solid rgba(255, 255, 255, 0.5); font-size: 26rpx; font-weight: 500; color: #444; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04); transition: all 0.2s; }
.logout-btn-glass:active { background: rgba(255, 255, 255, 0.6); transform: scale(0.96); }
.logout-icon { margin-right: 8rpx; opacity: 0.7; }

/* ================= 全新：文字区主题渐变色与纯图片头部样式 ================= */
.t-popup { border-radius: 40rpx 40rpx 0 0 !important; }

/* 弹窗外层基础容器 */
.unified-glass-popup { 
  background: #FFFFFF !important; /* 给定纯白底色 */
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
}

/* 纯图片头部，无缝贴合顶端 */
.brand-image-header { width: 100%; display: flex; justify-content: center; background: #FFF;}
.header-banner-img { width: 100%; height: auto; display: block; }

/* 核心修改：文字内容区 */
/* 把原本弹窗底部的安全距离移到这里，确保渐变色能铺满整个底部 */
.brand-content-fixed { 
  padding: 40rpx 50rpx calc(env(safe-area-inset-bottom) + 30rpx); 
}

/* 动态背景色：文字区域专属的 主题色 -> 白色 渐变 */
/* 起始颜色使用20%左右的透明度，既能彰显品牌主题，又能确保深灰文字绝对清晰 */
.bg-gradient-meituan { background: linear-gradient(180deg, rgba(255, 193, 7, 0.25) 0%, #FFFFFF 100%) !important; }
.bg-gradient-shunfeng { background: linear-gradient(180deg, rgba(211, 47, 47, 0.15) 0%, #FFFFFF 100%) !important; }
.bg-gradient-jingdong { background: linear-gradient(180deg, rgba(229, 57, 53, 0.15) 0%, #FFFFFF 100%) !important; }

/* 正文深灰色，保证彩色渐变底上的可读性 */
.auth-desc-fixed { font-size: 28rpx; color: #333; line-height: 1.7; text-align: justify; margin-bottom: 60rpx; }
.desc-sub-fixed { margin-top: 16rpx; color: #666; }
.bold-text-fixed { font-weight: 600; padding: 0 4rpx; color: #111; }
.highlight-text-fixed { font-weight: 700; padding: 0 4rpx; font-size: 30rpx; }

/* 品牌专属强调色 (高亮文字) */
.text-meituan { color: #FF9800; }
.text-shunfeng { color: #D32F2F; }
.text-jingdong { color: #E53935; }

/* 按钮样式 */
.auth-actions-fixed { display: flex; gap: 30rpx; }
.btn-cancel-outline, .btn-confirm-solid { 
  flex: 1; height: 96rpx; display: flex; justify-content: center; align-items: center; border-radius: 16rpx; font-size: 32rpx; font-weight: 600; 
}
/* 不验证：统一为白底灰字，弱化视觉 */
.btn-cancel-outline { background: #FFF; color: #666; border: 2rpx solid #E0E0E0; }
.btn-cancel-outline:active { background: #F5F5F5; }

/* 确认验证：使用品牌主色 */
.btn-confirm-solid { color: #FFF; }
.btn-meituan { background: linear-gradient(135deg, #FFC107 0%, #FF9800 100%); }
.btn-shunfeng { background: linear-gradient(135deg, #EF5350 0%, #D32F2F 100%); }
.btn-jingdong { background: linear-gradient(135deg, #E53935 0%, #B71C1C 100%); }
.btn-confirm-solid:active { opacity: 0.9; transform: scale(0.98); }