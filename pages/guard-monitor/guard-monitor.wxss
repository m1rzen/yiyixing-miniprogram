.monitor-page {
  min-height: 100vh;
  position: relative;
  background: var(--bg-primary);
}
.bg-top {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 360rpx;
  background: linear-gradient(170deg, #0A2538 0%, #0C2E45 45%, #1D5F8A 100%);
  z-index: 1;
}
.content {
  position: relative; z-index: 3;
  padding: 0 28rpx;
  min-height: 100vh;
}

.custom-nav { justify-content: flex-start; }
.nav-refresh {
  margin-left: auto;
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.10);
  border: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-refresh:active { background: rgba(255,255,255,0.2); }

/* 加载 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
  gap: 24rpx;
}
.loading-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

/* 访客概要 */
.visitor-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-lg);
  background: #FFF;
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
}
.vs-left { display: flex; align-items: center; gap: 16rpx; }
.vs-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--brand-color);
  display: flex;
  align-items: center;
  justify-content: center;
}
.vs-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.vs-detail {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4rpx;
}

/* 实时位置卡片 */
.realtime-card {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 28rpx;
  margin-bottom: 16rpx;
}
.rc-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}
.rc-indicator {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
}
.rc-indicator.live {
  background: var(--success-color);
  animation: blink 1.5s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(45,139,111,0.4); }
  50% { opacity: 0.6; box-shadow: 0 0 0 8rpx rgba(45,139,111,0.1); }
}
.rc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}
.rc-time { font-size: 22rpx; color: var(--text-tertiary); }
.rc-coords { display: flex; gap: 16rpx; }
.coord-item {
  flex: 1;
  padding: 16rpx 20rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
}
.coord-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 4rpx;
}
.coord-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  font-family: monospace;
  display: block;
}

/* 无位置 */
.no-location-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 36rpx;
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
}
.nl-text {
  font-size: 30rpx;
  color: var(--text-tertiary);
  margin-top: 16rpx;
}
.nl-sub {
  font-size: 24rpx;
  color: #D1D5DB;
  margin-top: 8rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
}
.sb-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.sb-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.sb-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}
.sb-divider {
  width: 2rpx; height: 48rpx;
  background: var(--border-color);
}

/* 时间线 */
.timeline-card {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 28rpx;
  margin-bottom: 16rpx;
}
.tl-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.tl-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.tl-auto {
  font-size: 22rpx;
  color: var(--success-color);
}
.tl-list { padding-left: 16rpx; }
.tl-item {
  display: flex;
  position: relative;
  padding-bottom: 28rpx;
}
.tl-item:last-child { padding-bottom: 0; }
.tl-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: var(--border-color);
  margin-top: 8rpx;
  position: relative;
  z-index: 2;
  flex-shrink: 0;
}
.tl-dot.latest {
  background: var(--success-color);
  box-shadow: 0 0 0 6rpx rgba(45,139,111,0.12);
}
.tl-connector {
  position: absolute;
  left: 7rpx; top: 24rpx; bottom: 0;
  width: 2rpx;
  background: var(--border-color);
  z-index: 1;
}
.tl-content { margin-left: 20rpx; flex: 1; }
.tl-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.tl-time {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}
.tl-badge {
  font-size: 20rpx;
  color: var(--success-color);
  background: var(--success-light);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}
.tl-coords-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 4rpx;
}
.tl-coord {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-family: monospace;
}
.tl-accuracy {
  font-size: 20rpx;
  color: var(--text-tertiary);
  background: var(--bg-primary);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

/* 提示 */
.tips-card {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  padding: 24rpx 28rpx;
  background: #FFF;
  border-radius: var(--radius-lg);
  margin-bottom: 40rpx;
}
.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
  flex: 1;
}
