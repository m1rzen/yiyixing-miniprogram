<view class="monitor-page">
  <view class="bg-top"></view>

  <view class="content immersive-content">
    <view class="custom-nav">
      <view class="nav-back" bindtap="goBack">
        <t-icon name="chevron-left" size="44rpx" color="#FFF" />
      </view>
      <text class="nav-title">实时位置监控</text>
      <view class="nav-refresh" bindtap="handleRefresh">
        <t-icon name="refresh" size="36rpx" color="#FFF" />
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{isLoading}}">
      <t-loading theme="circular" size="80rpx" />
      <text class="loading-text">加载中...</text>
    </view>

    <block wx:if="{{!isLoading}}">
      <!-- 访客信息概要 -->
      <view class="visitor-summary" wx:if="{{visit}}">
        <view class="vs-left">
          <view class="vs-avatar">
            <t-icon name="user" size="36rpx" color="#FFF" />
          </view>
          <view class="vs-info">
            <text class="vs-name">{{visit.visitorName}}</text>
            <text class="vs-detail">{{visit.community}} · {{visit.reason}}</text>
          </view>
        </view>
        <view class="vs-status">
          <view class="status-tag {{visit.isInside ? 'active' : 'approved'}}">
            {{visit.isInside ? '在场中' : '已通过'}}
          </view>
        </view>
      </view>

      <!-- 实时位置卡片 -->
      <view class="realtime-card" wx:if="{{visit && visit.lastLatitude}}">
        <view class="rc-header">
          <view class="rc-indicator live"></view>
          <text class="rc-title">最新位置</text>
          <text class="rc-time">{{lastRefreshTime}}</text>
        </view>
        <view class="rc-coords">
          <view class="coord-item">
            <text class="coord-label">纬度</text>
            <text class="coord-value">{{visit.lastLatitude}}</text>
          </view>
          <view class="coord-item">
            <text class="coord-label">经度</text>
            <text class="coord-value">{{visit.lastLongitude}}</text>
          </view>
        </view>
      </view>

      <view class="no-location-card" wx:if="{{!visit.lastLatitude && locations.length === 0}}">
        <t-icon name="map-blocked" size="80rpx" color="#D1D5DB" />
        <text class="nl-text">暂无位置信息</text>
        <text class="nl-sub">访客尚未开启位置打卡</text>
      </view>

      <!-- 统计信息 -->
      <view class="stats-bar" wx:if="{{totalLocations > 0}}">
        <view class="sb-item">
          <text class="sb-num">{{totalLocations}}</text>
          <text class="sb-label">总打卡次数</text>
        </view>
        <view class="sb-divider"></view>
        <view class="sb-item">
          <text class="sb-num">20s</text>
          <text class="sb-label">刷新间隔</text>
        </view>
        <view class="sb-divider"></view>
        <view class="sb-item">
          <text class="sb-num">{{locations.length}}</text>
          <text class="sb-label">已加载记录</text>
        </view>
      </view>

      <!-- 位置打卡时间线 -->
      <view class="timeline-card" wx:if="{{locations.length > 0}}">
        <view class="tl-header">
          <text class="tl-title">打卡时间线</text>
          <text class="tl-auto">自动刷新中</text>
        </view>
        <view class="tl-list">
          <view class="tl-item" wx:for="{{locations}}" wx:key="_id">
            <view class="tl-dot {{index === 0 ? 'latest' : ''}}"></view>
            <view class="tl-connector" wx:if="{{index < locations.length - 1}}"></view>
            <view class="tl-content">
              <view class="tl-row">
                <text class="tl-time">{{item.timestamp}}</text>
                <view class="tl-badge" wx:if="{{index === 0}}">最新</view>
              </view>
              <view class="tl-coords-row">
                <text class="tl-coord">{{item.latitude}}, {{item.longitude}}</text>
                <text class="tl-accuracy" wx:if="{{item.accuracy}}">精度 {{item.accuracy}}m</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 提示 -->
      <view class="tips-card">
        <t-icon name="info-circle" size="28rpx" color="#9CA3AF" />
        <text class="tips-text">位置数据每20秒自动刷新。访客位置仅在其进入小区后开启追踪采集，签退后自动停止。</text>
      </view>
    </block>
  </view>

  <t-toast id="t-toast" />
</view>
