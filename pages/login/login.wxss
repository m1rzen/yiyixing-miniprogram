.phone-login-page {
  min-height: 100vh;
  background-color: #F5F7FA;
  position: relative;
}

/* 顶部孔雀蓝氛围背景 */
.header-bg {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 360rpx;
  background: linear-gradient(180deg, #3F8DB4 0%, #F5F7FA 100%);
  z-index: 0;
}

.login-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 50rpx;
}

.page-title {
  display: flex;
  flex-direction: column;
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.title-main { font-size: 56rpx; font-weight: 600; color: #FFF; margin-bottom: 12rpx; text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); }
.title-sub { font-size: 28rpx; color: rgba(255,255,255,0.9); }

/* 输入框卡片 */
.input-card {
  background: #FFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(63, 141, 180, 0.08);
  margin-bottom: 60rpx;
}

.input-group { margin-bottom: 40rpx; }
.input-group:last-child { margin-bottom: 10rpx; }

.input-label { display: block; font-size: 28rpx; color: #555; font-weight: 500; margin-bottom: 20rpx; }

/* 微质感的输入框 */
.custom-input {
  width: 100%; height: 88rpx;
  background-color: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 32rpx; box-sizing: border-box;
  font-size: 32rpx; color: #333;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.custom-input:focus { border-color: #3F8DB4; background-color: #FFF; }
.ph-color { color: #BBB; font-weight: 300; font-size: 30rpx; }

.code-wrap { display: flex; justify-content: space-between; align-items: center; gap: 20rpx; }
.code-input { flex: 1; }
.get-code-btn {
  height: 88rpx; line-height: 88rpx; padding: 0 32rpx;
  background-color: rgba(63, 141, 180, 0.1);
  color: #3F8DB4; font-size: 28rpx; font-weight: 500;
  border-radius: 16rpx; white-space: nowrap;
}

/* 登录按钮 */
.submit-btn {
  width: 100%; height: 96rpx; line-height: 96rpx;
  background-color: #DDE5ED; color: #A0AAB5;
  border-radius: 20rpx; font-size: 34rpx; font-weight: 600;
  margin-bottom: 40rpx; transition: all 0.2s;
}
.submit-btn::after { border: none; }
.submit-btn.active { background-color: #3F8DB4; color: #FFF; box-shadow: 0 12rpx 30rpx rgba(63, 141, 180, 0.3); }
.btn-hover { transform: scale(0.98); opacity: 0.9; }

/* 协议勾选区 */
.agreement-box { display: flex; justify-content: center; align-items: center; gap: 8rpx; font-size: 24rpx; color: #777; }
.custom-checkbox { --td-checkbox-icon-checked-color: #3F8DB4; padding: 0 !important; margin: 0 !important; }
.agreement-text { display: flex; align-items: center; }
.link-text { color: #3F8DB4; font-weight: 500; }

/* 隐私弹窗样式 (复用欢迎页的高颜值弹窗) */
.privacy-popup { width: 620rpx; background: #FFFFFF; border-radius: 32rpx; display: flex; flex-direction: column; overflow: hidden; }
.privacy-header { font-size: 36rpx; font-weight: 600; color: #1A1A1A; text-align: center; padding: 40rpx 0 24rpx; border-bottom: 2rpx solid #F0F2F5; }
.privacy-content { height: 600rpx; padding: 32rpx 40rpx; box-sizing: border-box; }
.p-title { font-size: 28rpx; font-weight: 600; color: #3F8DB4; margin-bottom: 12rpx; margin-top: 32rpx; }
.p-title:first-child { margin-top: 0; }
.p-desc { font-size: 26rpx; color: #555555; line-height: 1.6; text-align: justify; }
.privacy-footer { padding: 32rpx 40rpx; border-top: 2rpx solid #F0F2F5; }
.privacy-btn { height: 80rpx !important; border-radius: 100rpx !important; font-size: 30rpx !important; background-color: #3F8DB4 !important;}