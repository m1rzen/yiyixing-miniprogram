.guard-dashboard {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* 头部 */
.gd-header { position: relative; }
.gd-header-bg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(170deg, #0A2538 0%, #0C2E45 45%, #1D5F8A 100%);
}
.gd-header-content {
  position: relative;
  padding: 110rpx 28rpx 28rpx;
}

.gd-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}
.gd-avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(200,150,62,0.2);
  border: 2rpx solid rgba(200,150,62,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}
.gd-user-info { flex: 1; }
.gd-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFF;
  display: block;
}
.gd-community {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-top: 4rpx;
}
.gd-actions { display: flex; gap: 12rpx; }
.gd-refresh, .gd-logout {
  width: 68rpx; height: 68rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}
.gd-refresh:active, .gd-logout:active {
  background: rgba(255,255,255,0.18);
}

/* 统计卡片 */
.stats-row { display: flex; gap: 16rpx; }
.stat-card {
  flex: 1;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.pending-stat {
  background: rgba(200,150,62,0.15);
  border: 1rpx solid rgba(200,150,62,0.2);
}
.active-stat {
  background: rgba(45,139,111,0.15);
  border: 1rpx solid rgba(45,139,111,0.2);
}
.stat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFF;
}
.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

/* Tabs */
.guard-tabs {
  --td-tab-item-color: var(--text-tertiary);
  --td-tab-track-color: var(--brand-color);
}

/* 列表 */
.list-container {
  padding: 16rpx 28rpx 32rpx;
  min-height: 60vh;
}
.visitor-card {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
  overflow: hidden;
}
.vc-header { padding: 24rpx 28rpx 14rpx; }
.vc-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.vc-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.vc-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4rpx;
}
.vc-body { padding: 0 28rpx 14rpx; }
.vc-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.vc-label { font-size: 26rpx; color: var(--text-tertiary); }
.vc-value { font-size: 26rpx; color: var(--text-primary); font-weight: 500; }
.vc-value.platform { color: var(--brand-color); }
.vc-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-top: 2rpx solid var(--border-color);
}
.vc-action-hint { font-size: 24rpx; color: var(--text-tertiary); }
.visitor-card:active { background: var(--bg-hover); }

.visitor-card.compact .vc-header { padding-bottom: 8rpx; }
.compact-body { padding-bottom: 24rpx; }
.vc-compact-info { font-size: 26rpx; color: var(--text-tertiary); }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 100rpx 0;
}
.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
