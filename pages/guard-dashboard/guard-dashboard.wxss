.guard-dashboard {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* 头部 */
.gd-header { position: relative; }
.gd-header-bg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(170deg, #0A2538 0%, #0C2E45 45%, #1D5F8A 100%);
}
.gd-header-content {
  position: relative;
  padding: 110rpx 28rpx 28rpx;
}

.gd-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.gd-avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(200,150,62,0.2);
  border: 2rpx solid rgba(200,150,62,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.gd-user-info { flex: 1; min-width: 0; }
.gd-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFF;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.gd-badge {
  font-size: 18rpx;
  background: rgba(200,150,62,0.8);
  color: #FFF;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 400;
}
.gd-community {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.gd-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}
.gd-action-btn {
  width: 68rpx; height: 68rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}
.gd-action-btn:active { background: rgba(255,255,255,0.18); }

/* 统计卡片 */
.stats-row { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.stat-card {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.pending-stat {
  background: rgba(200,150,62,0.15);
  border: 1rpx solid rgba(200,150,62,0.2);
}
.active-stat {
  background: rgba(45,139,111,0.15);
  border: 1rpx solid rgba(45,139,111,0.2);
}
.history-stat {
  background: rgba(29,95,138,0.2);
  border: 1rpx solid rgba(29,95,138,0.25);
}
.stat-icon-wrap {
  width: 44rpx; height: 44rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFF;
}
.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

/* 刷新时间 */
.refresh-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

/* Tab 自定义标签 */
.tab-label-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.tab-badge {
  min-width: 32rpx; height: 32rpx;
  border-radius: 16rpx;
  background: #C8963E;
  color: #FFF;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
.tab-badge-green { background: #2D8B6F; }

/* Tabs */
.guard-tabs {
  --td-tab-item-color: var(--text-tertiary);
  --td-tab-track-color: var(--brand-color);
}

/* 列表 */
.list-container {
  padding: 16rpx 24rpx 40rpx;
  min-height: 50vh;
}
.loading-card {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.visitor-card {
  background: #FFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 14rpx;
  overflow: hidden;
  transition: all 0.2s;
}
.card-hover { background: var(--bg-hover); transform: scale(0.995); }
.vc-header { padding: 22rpx 24rpx 12rpx; }
.vc-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}
.vc-live-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--success-color);
  animation: blink 1.5s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.vc-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.vc-verify-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}
.vc-verify-tag.verified {
  background: rgba(45,139,111,0.1);
  color: #2D8B6F;
}
.vc-verify-tag.new-visitor {
  background: rgba(200,150,62,0.1);
  color: #C8963E;
}
.vc-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
}
.vc-body { padding: 0 24rpx 12rpx; }
.vc-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.vc-label { font-size: 26rpx; color: var(--text-tertiary); }
.vc-value { font-size: 26rpx; color: var(--text-primary); font-weight: 500; }
.vc-value.platform-val { color: var(--brand-color); }
.vc-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-top: 2rpx solid var(--border-color);
}
.vc-action-hint { font-size: 24rpx; color: var(--text-tertiary); }

.visitor-card.compact .vc-header { padding-bottom: 6rpx; }
.compact-body { padding-bottom: 20rpx; }
.vc-compact-info { font-size: 26rpx; color: var(--text-tertiary); }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 100rpx 0;
}
.empty-icon-wrap {
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}
.empty-sub {
  font-size: 24rpx;
  color: #D1D5DB;
}
