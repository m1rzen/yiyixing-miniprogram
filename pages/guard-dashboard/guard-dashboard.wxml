<view class="guard-dashboard">
  <view class="gd-header">
    <view class="gd-header-bg"></view>
    <view class="gd-header-content">
      <view class="gd-user-row">
        <view class="gd-avatar">
          <t-icon name="user-safety" size="40rpx" color="#FFF" />
        </view>
        <view class="gd-user-info">
          <text class="gd-name">{{guardInfo.name || '保安'}} <text class="gd-badge">门岗</text></text>
          <text class="gd-community">{{guardInfo.community || '全部小区'}} · {{guardInfo.jobId}}</text>
        </view>
        <view class="gd-actions">
          <view class="gd-action-btn" bindtap="handleRefresh">
            <t-icon name="refresh" size="32rpx" color="#FFF" />
          </view>
          <view class="gd-action-btn" bindtap="handleLogout">
            <t-icon name="poweroff" size="28rpx" color="rgba(255,255,255,0.8)" />
          </view>
        </view>
      </view>

      <!-- 统计卡片 -->
      <view class="stats-row">
        <view class="stat-card pending-stat">
          <view class="stat-icon-wrap">
            <t-icon name="time-filled" size="32rpx" color="#C8963E" />
          </view>
          <text class="stat-num">{{pendingCount}}</text>
          <text class="stat-label">待审批</text>
        </view>
        <view class="stat-card active-stat">
          <view class="stat-icon-wrap">
            <t-icon name="user" size="32rpx" color="#2D8B6F" />
          </view>
          <text class="stat-num">{{activeCount}}</text>
          <text class="stat-label">在场人员</text>
        </view>
        <view class="stat-card history-stat">
          <view class="stat-icon-wrap">
            <t-icon name="time" size="32rpx" color="#1D5F8A" />
          </view>
          <text class="stat-num">{{historyCount}}</text>
          <text class="stat-label">今日记录</text>
        </view>
      </view>

      <!-- 刷新时间 -->
      <view class="refresh-time" wx:if="{{lastRefreshTime}}">
        <t-icon name="check-circle" size="20rpx" color="rgba(255,255,255,0.4)" />
        <text>{{lastRefreshTime}} 已更新</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <t-tabs value="{{currentTab}}" bind:change="onTabChange" t-class="guard-tabs">
    <t-tab-panel label="待审批" value="{{0}}">
      <view class="list-container">
        <!-- 加载中 -->
        <view class="loading-card" wx:if="{{isLoading}}">
          <t-loading theme="circular" size="60rpx" />
        </view>

        <view wx:if="{{!isLoading}}">
          <view
            class="visitor-card"
            wx:for="{{pendingList}}" wx:key="_id"
            bindtap="goToApproval" data-id="{{item._id}}"
            hover-class="card-hover"
          >
            <view class="vc-header">
              <view class="vc-name-row">
                <text class="vc-name">{{item.visitorName}}</text>
                <view class="vc-verify-tag verified" wx:if="{{item.userIdentityVerified}}">已认证</view>
                <view class="vc-verify-tag new-visitor" wx:else>首次</view>
                <view class="status-tag pending">待审批</view>
              </view>
              <text class="vc-time">{{item.createTimeStr || '-'}}</text>
            </view>
            <view class="vc-body">
              <view class="vc-row" wx:if="{{item.userIdentityVerified}}">
                <text class="vc-label">认证信息</text>
                <text class="vc-value" style="color:#2D8B6F;">来访{{item.userTotalVisits}}次 · {{item.userVerifiedCommunity}}认证</text>
              </view>
              <view class="vc-row">
                <text class="vc-label">手机号</text>
                <text class="vc-value">{{item.visitorPhone}}</text>
              </view>
              <view class="vc-row">
                <text class="vc-label">拜访小区</text>
                <text class="vc-value">{{item.community}}</text>
              </view>
              <view class="vc-row">
                <text class="vc-label">拜访事由</text>
                <text class="vc-value">{{item.reason}}</text>
              </view>
              <view class="vc-row" wx:if="{{item.platform && item.platform !== '普通访客'}}">
                <text class="vc-label">来源平台</text>
                <text class="vc-value platform-val">{{item.platform}}</text>
              </view>
            </view>
            <view class="vc-footer">
              <text class="vc-action-hint">点击审批</text>
              <t-icon name="chevron-right" size="28rpx" color="#9CA3AF" />
            </view>
          </view>

          <view class="empty-state" wx:if="{{pendingList.length === 0}}">
            <view class="empty-icon-wrap">
              <t-icon name="check-circle" size="64rpx" color="#D1D5DB" />
            </view>
            <text class="empty-text">暂无待审批申请</text>
            <text class="empty-sub">下拉或点击右上角刷新</text>
          </view>
        </view>
      </view>
    </t-tab-panel>

    <t-tab-panel label="在场人员" value="{{1}}">
      <view class="list-container">
        <view class="loading-card" wx:if="{{isLoading}}">
          <t-loading theme="circular" size="60rpx" />
        </view>

        <view wx:if="{{!isLoading}}">
          <view
            class="visitor-card"
            wx:for="{{activeList}}" wx:key="_id"
            bindtap="goToMonitor" data-id="{{item._id}}"
            hover-class="card-hover"
          >
            <view class="vc-header">
              <view class="vc-name-row">
                <view class="vc-live-dot"></view>
                <text class="vc-name">{{item.visitorName}}</text>
                <view class="status-tag active">在场中</view>
              </view>
              <text class="vc-time">入场 {{item.approveTimeStr || '-'}}</text>
            </view>
            <view class="vc-body">
              <view class="vc-row">
                <text class="vc-label">拜访小区</text>
                <text class="vc-value">{{item.community}}</text>
              </view>
              <view class="vc-row">
                <text class="vc-label">拜访事由</text>
                <text class="vc-value">{{item.reason}}</text>
              </view>
              <view class="vc-row" wx:if="{{item.lastLocationTime}}">
                <text class="vc-label">最近打卡</text>
                <text class="vc-value">{{item.lastLocationTime}}</text>
              </view>
            </view>
            <view class="vc-footer">
              <t-icon name="map-information" size="26rpx" color="#1D5F8A" />
              <text class="vc-action-hint" style="color: #1D5F8A;">查看实时位置</text>
              <t-icon name="chevron-right" size="28rpx" color="#9CA3AF" />
            </view>
          </view>

          <view class="empty-state" wx:if="{{activeList.length === 0}}">
            <view class="empty-icon-wrap">
              <t-icon name="user" size="64rpx" color="#D1D5DB" />
            </view>
            <text class="empty-text">当前无在场外来人员</text>
            <text class="empty-sub">所有访客均已离场</text>
          </view>
        </view>
      </view>
    </t-tab-panel>

    <t-tab-panel label="历史记录" value="{{2}}">
      <view class="list-container">
        <view class="loading-card" wx:if="{{isLoading}}">
          <t-loading theme="circular" size="60rpx" />
        </view>

        <view wx:if="{{!isLoading}}">
          <view
            class="visitor-card compact"
            wx:for="{{historyList}}" wx:key="_id"
          >
            <view class="vc-header">
              <view class="vc-name-row">
                <text class="vc-name">{{item.visitorName}}</text>
                <view class="status-tag {{item.status === 'approved' ? 'approved' : item.status === 'rejected' ? 'rejected' : item.status === 'completed' ? 'approved' : 'pending'}}">
                  {{item.status === 'approved' ? '通行中' : item.status === 'rejected' ? '已驳回' : item.status === 'completed' ? '已签退' : '待审批'}}
                </view>
              </view>
              <text class="vc-time">{{item.createTimeStr || '-'}}</text>
            </view>
            <view class="vc-body compact-body">
              <text class="vc-compact-info">{{item.community}} · {{item.reason}}</text>
            </view>
          </view>

          <view class="empty-state" wx:if="{{historyList.length === 0}}">
            <view class="empty-icon-wrap">
              <t-icon name="time" size="64rpx" color="#D1D5DB" />
            </view>
            <text class="empty-text">暂无历史记录</text>
          </view>
        </view>
      </view>
    </t-tab-panel>
  </t-tabs>

  <t-toast id="t-toast" />
</view>
