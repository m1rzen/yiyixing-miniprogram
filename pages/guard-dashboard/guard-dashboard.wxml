<view class="guard-dashboard">
  <view class="gd-header">
    <view class="gd-header-bg"></view>
    <view class="gd-header-content">
      <view class="gd-user-row">
        <view class="gd-avatar">
          <t-icon name="user-safety" size="40rpx" color="#FFF" />
        </view>
        <view class="gd-user-info">
          <text class="gd-name">{{guardInfo.name || '保安'}}</text>
          <text class="gd-community">{{guardInfo.community || '全部小区'}} · 工号 {{guardInfo.jobId}}</text>
        </view>
        <view class="gd-actions">
          <view class="gd-refresh" bindtap="handleRefresh">
            <t-icon name="refresh" size="36rpx" color="#FFF" />
          </view>
          <view class="gd-logout" bindtap="handleLogout">
            <t-icon name="poweroff" size="32rpx" color="rgba(255,255,255,0.8)" />
          </view>
        </view>
      </view>

      <!-- 统计卡片 -->
      <view class="stats-row">
        <view class="stat-card pending-stat">
          <text class="stat-num">{{pendingCount}}</text>
          <text class="stat-label">待审批</text>
        </view>
        <view class="stat-card active-stat">
          <text class="stat-num">{{activeCount}}</text>
          <text class="stat-label">在场人员</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <t-tabs defaultValue="{{0}}" bind:change="onTabChange" t-class="guard-tabs">
    <t-tab-panel label="待审批" value="{{0}}">
      <view class="list-container">
        <view class="visitor-card" wx:for="{{pendingList}}" wx:key="_id" bindtap="goToApproval" data-id="{{item._id}}">
          <view class="vc-header">
            <view class="vc-name-row">
              <text class="vc-name">{{item.visitorName}}</text>
              <view class="status-tag pending">待审批</view>
            </view>
            <text class="vc-time">{{item.createTime}}</text>
          </view>
          <view class="vc-body">
            <view class="vc-row">
              <text class="vc-label">手机号</text>
              <text class="vc-value">{{item.visitorPhone}}</text>
            </view>
            <view class="vc-row">
              <text class="vc-label">小区</text>
              <text class="vc-value">{{item.community}}</text>
            </view>
            <view class="vc-row">
              <text class="vc-label">事由</text>
              <text class="vc-value">{{item.reason}}</text>
            </view>
            <view class="vc-row" wx:if="{{item.platform && item.platform !== '普通访客'}}">
              <text class="vc-label">平台</text>
              <text class="vc-value platform">{{item.platform}}</text>
            </view>
          </view>
          <view class="vc-footer">
            <t-icon name="chevron-right" size="32rpx" color="#9CA3AF" />
            <text class="vc-action-hint">点击审批</text>
          </view>
        </view>

        <view class="empty-state" wx:if="{{pendingList.length === 0 && !isLoading}}">
          <t-icon name="check-circle" size="80rpx" color="#D1D5DB" />
          <text class="empty-text">暂无待审批申请</text>
        </view>
      </view>
    </t-tab-panel>

    <t-tab-panel label="在场人员" value="{{1}}">
      <view class="list-container">
        <view class="visitor-card" wx:for="{{activeList}}" wx:key="_id" bindtap="goToMonitor" data-id="{{item._id}}">
          <view class="vc-header">
            <view class="vc-name-row">
              <text class="vc-name">{{item.visitorName}}</text>
              <view class="status-tag active">在场</view>
            </view>
          </view>
          <view class="vc-body">
            <view class="vc-row">
              <text class="vc-label">小区</text>
              <text class="vc-value">{{item.community}}</text>
            </view>
            <view class="vc-row">
              <text class="vc-label">事由</text>
              <text class="vc-value">{{item.reason}}</text>
            </view>
            <view class="vc-row" wx:if="{{item.lastLocationTime}}">
              <text class="vc-label">最近打卡</text>
              <text class="vc-value">{{item.lastLocationTime}}</text>
            </view>
          </view>
          <view class="vc-footer">
            <t-icon name="map-information" size="28rpx" color="#1D5F8A" />
            <text class="vc-action-hint" style="color: #1D5F8A;">查看实时位置</text>
          </view>
        </view>

        <view class="empty-state" wx:if="{{activeList.length === 0 && !isLoading}}">
          <t-icon name="user" size="80rpx" color="#D1D5DB" />
          <text class="empty-text">当前无在场外来人员</text>
        </view>
      </view>
    </t-tab-panel>

    <t-tab-panel label="历史记录" value="{{2}}">
      <view class="list-container">
        <view class="visitor-card compact" wx:for="{{historyList}}" wx:key="_id">
          <view class="vc-header">
            <view class="vc-name-row">
              <text class="vc-name">{{item.visitorName}}</text>
              <view class="status-tag {{item.status === 'approved' ? 'approved' : item.status === 'rejected' ? 'rejected' : 'pending'}}">
                {{item.status === 'approved' ? '已通过' : item.status === 'rejected' ? '已驳回' : item.status === 'completed' ? '已签退' : '未知'}}
              </view>
            </view>
          </view>
          <view class="vc-body compact-body">
            <text class="vc-compact-info">{{item.community}} · {{item.reason}}</text>
          </view>
        </view>

        <view class="empty-state" wx:if="{{historyList.length === 0 && !isLoading}}">
          <t-icon name="time" size="80rpx" color="#D1D5DB" />
          <text class="empty-text">暂无历史记录</text>
        </view>
      </view>
    </t-tab-panel>
  </t-tabs>

  <t-toast id="t-toast" />
</view>
